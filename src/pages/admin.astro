---
import AdminApp from '../components/AdminApp';
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>博客编辑器 | 晨熠</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="notion-body">
    <AdminApp client:only="react" />
  </body>
</html>

<style is:global>
  /* ===== Notion 风格编辑器 - 亮色主题 ===== */
  .notion-body {
    margin: 0;
    padding: 0;
    font-family: 'Inter', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #fff;
    color: #37352F;
    overflow: hidden;
    height: 100vh;
  }

  .notion-app {
    display: flex;
    height: 100vh;
    overflow: hidden;
  }

  /* === 侧栏 === */
  .notion-sidebar {
    width: 260px;
    min-width: 260px;
    background: #F7F6F3;
    border-right: 1px solid #E8E7E4;
    display: flex;
    flex-direction: column;
    height: 100vh;
    overflow: hidden;
  }

  .sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 12px 8px;
    border-bottom: 1px solid #E8E7E4;
  }

  .sidebar-logo {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .logo-icon {
    font-size: 18px;
    color: #D97706;
  }

  .logo-text {
    font-weight: 600;
    font-size: 14px;
    color: #37352F;
  }

  .sidebar-icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 16px;
    padding: 4px;
    border-radius: 4px;
    transition: background 0.15s;
  }

  .sidebar-icon-btn:hover {
    background: rgba(55, 53, 47, 0.08);
  }

  .sidebar-settings {
    padding: 12px;
    border-bottom: 1px solid #E8E7E4;
    background: #F1F0EC;
  }

  .settings-label {
    font-size: 12px;
    font-weight: 500;
    color: #9B9A97;
    margin-bottom: 6px;
    display: block;
  }

  .settings-input {
    width: 100%;
    padding: 6px 8px;
    border: 1px solid #E8E7E4;
    border-radius: 4px;
    font-size: 13px;
    background: #fff;
    color: #37352F;
    outline: none;
    box-sizing: border-box;
  }

  .settings-input:focus {
    border-color: #D97706;
    box-shadow: 0 0 0 2px rgba(217, 119, 6, 0.15);
  }

  .settings-hint {
    font-size: 11px;
    color: #9B9A97;
    margin: 6px 0 0;
  }

  .settings-hint a {
    color: #D97706;
    text-decoration: none;
  }

  .sidebar-actions {
    padding: 8px 12px;
  }

  .sidebar-new-btn {
    width: 100%;
    padding: 7px 12px;
    background: none;
    border: 1px dashed #D3D1CB;
    border-radius: 6px;
    cursor: pointer;
    font-size: 13px;
    color: #9B9A97;
    transition: all 0.15s;
    text-align: left;
  }

  .sidebar-new-btn:hover {
    background: rgba(55, 53, 47, 0.06);
    border-color: #D97706;
    color: #37352F;
  }

  .sidebar-posts {
    flex: 1;
    overflow-y: auto;
    padding: 4px 8px;
  }

  .sidebar-section-title {
    font-size: 11px;
    font-weight: 600;
    color: #9B9A97;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    padding: 8px 8px 4px;
  }

  .sidebar-post-item {
    width: 100%;
    padding: 6px 8px;
    background: none;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    text-align: left;
    transition: background 0.12s;
    margin-bottom: 1px;
  }

  .sidebar-post-item:hover {
    background: rgba(55, 53, 47, 0.06);
  }

  .sidebar-post-active {
    background: rgba(217, 119, 6, 0.1) !important;
  }

  .post-item-title {
    font-size: 13px;
    color: #37352F;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .post-item-date {
    font-size: 11px;
    color: #9B9A97;
    margin-top: 2px;
  }

  .sidebar-empty {
    font-size: 13px;
    color: #9B9A97;
    text-align: center;
    padding: 24px;
  }

  .sidebar-footer {
    padding: 8px 12px;
    border-top: 1px solid #E8E7E4;
  }

  .sidebar-sync-btn {
    width: 100%;
    padding: 8px 12px;
    background: #37352F;
    color: #fff;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-size: 13px;
    font-weight: 500;
    transition: background 0.15s;
  }

  .sidebar-sync-btn:hover:not(:disabled) {
    background: #2F2D2A;
  }

  .sidebar-sync-btn:disabled {
    background: #D3D1CB;
    cursor: not-allowed;
  }

  /* === 主内容区 === */
  .notion-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: #fff;
  }

  .notion-topbar {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 24px;
    border-bottom: 1px solid #E8E7E4;
    background: #fff;
  }

  .notion-title-input {
    flex: 1;
    border: none;
    font-size: 16px;
    font-weight: 600;
    color: #37352F;
    outline: none;
    background: none;
  }

  .notion-title-input::placeholder {
    color: #C8C7C5;
  }

  .topbar-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .notion-date-input,
  .notion-tags-input {
    padding: 4px 8px;
    border: 1px solid #E8E7E4;
    border-radius: 4px;
    font-size: 12px;
    color: #9B9A97;
    outline: none;
    background: #F7F6F3;
  }

  .notion-date-input:focus,
  .notion-tags-input:focus {
    border-color: #D97706;
  }

  .dirty-dot {
    color: #D97706;
    font-size: 10px;
    animation: pulse-dot 1.5s infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* === 消息提示 === */
  .notion-message {
    padding: 8px 16px;
    font-size: 13px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .notion-msg-ok {
    background: #D3F9D8;
    color: #2B8A3E;
  }

  .notion-msg-err {
    background: #FFE3E3;
    color: #E03131;
  }

  .msg-close {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    opacity: 0.6;
  }

  .msg-close:hover { opacity: 1; }

  /* === 编辑器区域 === */
  .notion-editor-area {
    flex: 1;
    overflow-y: auto;
  }

  .notion-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: #9B9A97;
    font-size: 14px;
  }

  .notion-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    color: #9B9A97;
  }

  .empty-icon {
    font-size: 48px;
    color: #D97706;
    margin-bottom: 16px;
  }

  .empty-hint {
    font-size: 13px;
    margin-top: 8px;
    color: #C8C7C5;
  }

  /* === 编辑器包装器 === */
  .notion-editor-wrapper {
    max-width: 800px;
    margin: 0 auto;
    padding: 24px 48px 80px;
  }

  /* === 工具栏 === */
  .notion-toolbar {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 6px 8px;
    border-bottom: 1px solid #E8E7E4;
    background: #F7F6F3;
    border-radius: 8px;
    margin-bottom: 20px;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .toolbar-group {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .toolbar-divider {
    width: 1px;
    height: 20px;
    background: #E8E7E4;
    margin: 0 4px;
  }

  .toolbar-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px 7px;
    border-radius: 4px;
    font-size: 13px;
    color: #6B6A68;
    transition: all 0.12s;
    font-family: inherit;
    line-height: 1;
  }

  .toolbar-btn:hover {
    background: rgba(55, 53, 47, 0.08);
    color: #37352F;
  }

  .toolbar-btn-active {
    background: rgba(55, 53, 47, 0.1) !important;
    color: #37352F !important;
    font-weight: 600;
  }

  /* 颜色选择器 */
  .color-picker-wrapper,
  .link-wrapper {
    position: relative;
  }

  .color-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-left: 2px;
    vertical-align: middle;
  }

  .color-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    background: #fff;
    border: 1px solid #E8E7E4;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    padding: 6px;
    z-index: 50;
    min-width: 160px;
  }

  .color-dropdown-title {
    font-size: 11px;
    font-weight: 600;
    color: #9B9A97;
    padding: 4px 8px;
    text-transform: uppercase;
  }

  .color-option {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 5px 8px;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: 4px;
    font-size: 13px;
    color: #37352F;
    width: 100%;
    text-align: left;
  }

  .color-option:hover {
    background: rgba(55, 53, 47, 0.06);
  }

  .color-preview {
    width: 18px;
    height: 18px;
    border-radius: 4px;
    flex-shrink: 0;
  }

  /* 链接输入 */
  .link-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    background: #fff;
    border: 1px solid #E8E7E4;
    border-radius: 8px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    padding: 8px;
    z-index: 50;
    display: flex;
    gap: 6px;
  }

  .link-input {
    padding: 5px 8px;
    border: 1px solid #E8E7E4;
    border-radius: 4px;
    font-size: 13px;
    width: 240px;
    outline: none;
  }

  .link-input:focus {
    border-color: #D97706;
  }

  .link-confirm {
    padding: 5px 12px;
    background: #37352F;
    color: #fff;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    white-space: nowrap;
  }

  .link-confirm:hover {
    background: #2F2D2A;
  }

  /* === TipTap 编辑区 === */
  .notion-editor-content {
    min-height: 400px;
  }

  .notion-prose {
    outline: none;
    min-height: 60vh;
  }

  .notion-prose p.is-editor-empty:first-child::before {
    content: attr(data-placeholder);
    float: left;
    color: #C8C7C5;
    pointer-events: none;
    height: 0;
  }

  /* Notion 风格排版 */
  .notion-prose h1 {
    font-size: 28px;
    font-weight: 700;
    color: #37352F;
    margin-top: 32px;
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .notion-prose h2 {
    font-size: 22px;
    font-weight: 600;
    color: #37352F;
    margin-top: 24px;
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .notion-prose h3 {
    font-size: 18px;
    font-weight: 600;
    color: #37352F;
    margin-top: 20px;
    margin-bottom: 4px;
    line-height: 1.3;
  }

  .notion-prose p {
    margin: 4px 0;
    line-height: 1.7;
    color: #37352F;
  }

  .notion-prose strong { font-weight: 600; }
  .notion-prose em { font-style: italic; }

  .notion-prose code {
    background: #F1F0EC;
    color: #EB5757;
    padding: 2px 5px;
    border-radius: 3px;
    font-size: 0.9em;
    font-family: 'JetBrains Mono', monospace;
  }

  .notion-prose pre {
    background: #F7F6F3;
    border: 1px solid #E8E7E4;
    border-radius: 6px;
    padding: 16px;
    overflow-x: auto;
    margin: 8px 0;
  }

  .notion-prose pre code {
    background: none;
    color: #37352F;
    padding: 0;
    font-size: 13px;
  }

  .notion-prose blockquote {
    border-left: 3px solid #37352F;
    padding-left: 14px;
    margin: 8px 0;
    color: #6B6A68;
  }

  .notion-prose ul,
  .notion-prose ol {
    padding-left: 24px;
    margin: 4px 0;
  }

  .notion-prose li { margin: 2px 0; }

  .notion-prose hr {
    border: none;
    border-top: 1px solid #E8E7E4;
    margin: 16px 0;
  }

  .notion-prose a.notion-link {
    color: #D97706;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .notion-prose a.notion-link:hover {
    color: #B45309;
  }

  .notion-prose img.notion-image {
    max-width: 100%;
    border-radius: 6px;
    margin: 12px 0;
  }

  .notion-prose mark {
    border-radius: 2px;
    padding: 1px 3px;
  }

  /* 状态栏 */
  .notion-statusbar {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    font-size: 11px;
    color: #C8C7C5;
    border-top: 1px solid #F1F0EC;
    margin-top: 16px;
  }

  /* 滚动条 */
  .notion-editor-area::-webkit-scrollbar,
  .sidebar-posts::-webkit-scrollbar {
    width: 6px;
  }

  .notion-editor-area::-webkit-scrollbar-track,
  .sidebar-posts::-webkit-scrollbar-track {
    background: transparent;
  }

  .notion-editor-area::-webkit-scrollbar-thumb,
  .sidebar-posts::-webkit-scrollbar-thumb {
    background: #D3D1CB;
    border-radius: 3px;
  }

  .notion-editor-area::-webkit-scrollbar-thumb:hover,
  .sidebar-posts::-webkit-scrollbar-thumb:hover {
    background: #B8B7B4;
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .notion-sidebar { width: 200px; min-width: 200px; }
    .notion-editor-wrapper { padding: 16px 20px 60px; }
  }
</style>
