---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import LocalIcon from '../../components/LocalIcon.astro';
import { getCategoryMeta } from '../../utils/categoryMeta';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const categories = Array.from(new Set(posts.map((post) => post.data.category || '未分类')));
  return categories.map((category) => ({
    params: { category },
    props: { category },
  }));
}

const { category } = Astro.props;
const posts = (await getCollection('blog'))
  .filter((post) => (post.data.category || '未分类') === category)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const meta = getCategoryMeta(category);
---

<BaseLayout title={`${category} 分类`} description={`浏览 ${category} 分类下的博客文章`}>
  <Header />
  <main class="max-w-5xl mx-auto px-6 py-10 flex-1">
    <div class="mb-8 rounded-[2rem] border border-emerald-200 bg-[linear-gradient(135deg,rgba(236,253,245,0.94),rgba(255,255,255,0.96))] p-8 shadow-[0_18px_48px_rgba(16,185,129,0.10)]">
      <a href="/categories" class="inline-flex items-center gap-1 text-sm text-emerald-700 hover:text-emerald-600 transition-colors">
        <span aria-hidden="true">←</span>
        返回分类总览
      </a>
      <div class="mt-4 inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white/90 px-4 py-2 text-sm text-emerald-700">
        <LocalIcon name={meta.icon} class="h-4 w-4" />
        {category}
      </div>
      <h1 class="mt-4 text-4xl font-bold text-slate-900">{category}</h1>
      <p class="mt-3 text-slate-600">这个分类下目前有 {posts.length} 篇文章。</p>
    </div>

    <div class="space-y-4">
      {posts.map((post) => {
        const formattedDate = post.data.pubDate.toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });

        return (
          <a
            href={`/blog/${post.id}`}
            class="group block rounded-[1.75rem] border border-stone-200 bg-white/88 px-6 py-5 shadow-[0_16px_40px_rgba(148,163,184,0.08)] transition-all duration-300 hover:-translate-y-0.5 hover:border-emerald-300 hover:shadow-[0_18px_44px_rgba(16,185,129,0.10)]"
          >
            <div class="flex items-start justify-between gap-4">
              <div class="min-w-0 flex-1">
                <div class="flex flex-wrap items-center gap-2">
                  <span class={`inline-flex items-center gap-1.5 rounded-full border px-2.5 py-1 text-xs ${meta.soft} ${meta.accent} ${meta.ring}`}>
                    <LocalIcon name={meta.icon} class="h-3.5 w-3.5" />
                    {category}
                  </span>
                  <span class="rounded-full border border-amber-300/40 bg-amber-50 px-2.5 py-1 text-xs text-amber-700">
                    {formattedDate}
                  </span>
                </div>
                <h2 class="mt-3 text-xl font-semibold text-slate-900 transition-colors group-hover:text-emerald-700">
                  {post.data.title}
                </h2>
                {post.data.description && (
                  <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-slate-600">
                    {post.data.description}
                  </p>
                )}
                {post.data.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {post.data.tags.map((tag) => (
                      <span class="rounded-full border border-sky-200 bg-sky-50 px-2 py-0.5 text-[11px] text-sky-700">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
              <span class="mt-1 shrink-0 text-slate-300 transition-colors group-hover:text-emerald-500">↗</span>
            </div>
          </a>
        );
      })}
    </div>
  </main>
  <Footer />
</BaseLayout>
