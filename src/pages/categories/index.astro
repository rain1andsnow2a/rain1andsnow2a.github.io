---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import LocalIcon from '../../components/LocalIcon.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categoryMap = posts.reduce((acc, post) => {
  const key = post.data.category || '未分类';
  if (!acc.has(key)) acc.set(key, []);
  acc.get(key)?.push(post);
  return acc;
}, new Map<string, typeof posts>());

const categories = Array.from(categoryMap.entries()).sort((a, b) => {
  if (a[0] === '未分类') return 1;
  if (b[0] === '未分类') return -1;
  return a[0].localeCompare(b[0], 'zh-CN');
});
---

<BaseLayout title="分类" description="按分类浏览晨熠的博客文章">
  <Header />
  <main class="flex-1">
    <section class="border-b border-stone-200 bg-[linear-gradient(180deg,rgba(237,253,250,0.9),rgba(255,255,255,0.95))]">
      <div class="max-w-5xl mx-auto px-6 py-16">
        <div class="inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white/80 px-4 py-2 text-sm text-emerald-700 shadow-sm">
          <LocalIcon name="book-open" class="h-4 w-4" />
          分类导航
        </div>
        <h1 class="mt-5 text-4xl font-bold text-slate-900">Categories</h1>
        <p class="mt-3 max-w-2xl text-slate-600 leading-relaxed">
          把技术探索按主题整理成更清晰的知识分区，你可以从这里按分类进入对应文章集合。
        </p>
      </div>
    </section>

    <section class="max-w-5xl mx-auto px-6 py-10">
      <div class="grid gap-5 md:grid-cols-[minmax(0,2fr)_320px]">
        <div class="rounded-[2rem] border border-stone-200 bg-white/85 p-8 shadow-[0_18px_48px_rgba(148,163,184,0.10)]">
          <div class="space-y-4">
            {categories.map(([category, items]) => (
              <a
                href={`/categories/${encodeURIComponent(category)}`}
                class="group flex items-center justify-between rounded-2xl border border-stone-200 bg-stone-50/70 px-5 py-4 transition-all duration-300 hover:-translate-y-0.5 hover:border-emerald-300 hover:bg-emerald-50/70 hover:shadow-[0_12px_30px_rgba(16,185,129,0.10)]"
              >
                <span class="flex items-center gap-3 min-w-0">
                  <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-emerald-100 text-emerald-700">
                    <LocalIcon name="file-text" class="h-4 w-4" />
                  </span>
                  <span class="min-w-0">
                    <span class="block truncate text-lg font-semibold text-slate-800 group-hover:text-emerald-800">
                      {category}
                    </span>
                    <span class="block mt-1 text-sm text-slate-500">
                      最近更新：{items[0]?.data.title}
                    </span>
                  </span>
                </span>
                <span class="shrink-0 rounded-full border border-emerald-200 bg-white px-3 py-1 text-sm font-medium text-emerald-700">
                  {items.length} 篇
                </span>
              </a>
            ))}
          </div>
        </div>

        <aside class="rounded-[2rem] border border-stone-200 bg-white/85 p-8 shadow-[0_18px_48px_rgba(148,163,184,0.10)]">
          <div class="mx-auto h-24 w-24 overflow-hidden rounded-full border-4 border-emerald-100 shadow-[0_18px_32px_rgba(16,185,129,0.16)]">
            <img
              src="/头像.png"
              alt="晨熠的头像"
              class="h-full w-full object-cover"
            />
          </div>
          <h2 class="mt-5 text-center text-3xl font-semibold text-slate-900">晨熠</h2>
          <p class="mt-3 text-center text-slate-600 leading-relaxed">
            分类不是为了把内容关进盒子，而是为了更快找到下一条值得深入的线索。
          </p>

          <div class="mt-8 grid grid-cols-3 gap-3 text-center">
            <div>
              <div class="text-xs uppercase tracking-[0.2em] text-slate-400">文章</div>
              <div class="mt-2 text-3xl font-semibold text-slate-900">{posts.length}</div>
            </div>
            <div>
              <div class="text-xs uppercase tracking-[0.2em] text-slate-400">标签</div>
              <div class="mt-2 text-3xl font-semibold text-slate-900">{new Set(posts.flatMap((post) => post.data.tags)).size}</div>
            </div>
            <div>
              <div class="text-xs uppercase tracking-[0.2em] text-slate-400">分类</div>
              <div class="mt-2 text-3xl font-semibold text-slate-900">{categories.length}</div>
            </div>
          </div>

          <a
            href="https://github.com/rain1andsnow2a"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-slate-900 px-4 py-3 text-white transition-colors hover:bg-slate-800"
          >
            <LocalIcon name="github" class="h-4 w-4" />
            Follow Me
          </a>
        </aside>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
