---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import LocalIcon from '../../components/LocalIcon.astro';
import { getCategoryMeta } from '../../utils/categoryMeta';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categoryMap = posts.reduce((acc, post) => {
  const key = post.data.category || '未分类';
  if (!acc.has(key)) acc.set(key, []);
  acc.get(key)?.push(post);
  return acc;
}, new Map<string, typeof posts>());

const categories = Array.from(categoryMap.entries()).sort((a, b) => {
  if (a[0] === '未分类') return 1;
  if (b[0] === '未分类') return -1;
  return a[0].localeCompare(b[0], 'zh-CN');
});
---

<BaseLayout title="分类" description="按分类浏览晨熠的博客文章">
  <Header />
  <main
    class="category-tune-surface flex-1"
    data-category-title-font="sans"
    data-category-copy-font="sans"
    data-category-badge-font="sans"
    data-category-card-font="sans"
  >
    <section class="relative overflow-hidden border-b border-stone-200 bg-white">
      <img
        src="/category_background.png"
        alt=""
        aria-hidden="true"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-white/45"></div>
      <div class="relative max-w-6xl mx-auto px-6 py-16 lg:py-20">
        <div class="category-hero-badge inline-flex items-center gap-2 rounded-full border border-emerald-200 bg-white/85 px-4 py-2 font-medium shadow-[0_10px_28px_rgba(16,185,129,0.14)] backdrop-blur-sm">
          <LocalIcon name="layout-grid" class="h-4 w-4" />
          分类导航
        </div>
        <h1 class="category-hero-title">Categories</h1>
        <p class="category-hero-copy">
          把技术探索按主题整理成更清晰的知识分区，你可以从这里按分类进入对应文章集合。
        </p>
        <div class="category-hero-rule"></div>
      </div>
    </section>

    <section class="bg-[linear-gradient(180deg,#fffaf2_0%,#ffffff_58%,#f8fffc_100%)]">
      <div class="max-w-6xl mx-auto px-6 py-8 lg:py-10">
        <div class="grid gap-6 lg:grid-cols-[minmax(0,1fr)_330px]">
          <div class="space-y-3">
            {categories.map(([category, items], index) => {
              const meta = getCategoryMeta(category, index);

              return (
              <a
                href={`/categories/${encodeURIComponent(category)}`}
                class="category-card group flex items-center justify-between rounded-2xl border border-stone-200 bg-white/92 px-5 py-4 shadow-[0_10px_30px_rgba(15,23,42,0.05)] transition-all duration-300 hover:-translate-y-0.5 hover:border-emerald-200 hover:shadow-[0_16px_36px_rgba(16,185,129,0.10)]"
              >
                <span class="flex items-center gap-3 min-w-0">
                  <span class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl border ${meta.soft} ${meta.accent} ${meta.ring}`}>
                    <LocalIcon name={meta.icon} class="h-5 w-5" />
                  </span>
                  <span class="min-w-0">
                    <span class="category-card-title block truncate font-semibold text-slate-800 group-hover:text-emerald-800">
                      {category}
                    </span>
                    <span class="category-card-desc block mt-1 text-slate-500">
                      最近更新：{items[0]?.data.title}
                    </span>
                  </span>
                </span>
                <span class="flex shrink-0 items-center gap-4">
                  <span class="rounded-full border border-emerald-200 bg-white px-3 py-1 text-sm font-medium text-emerald-700">
                    {items.length} 篇
                  </span>
                  <LocalIcon name="chevron-right" class="h-5 w-5 text-slate-300 transition-all duration-300 group-hover:translate-x-1 group-hover:text-emerald-500" />
                </span>
              </a>
              );
            })}
          </div>

          <aside class="space-y-4">
            <section class="rounded-[1.6rem] border border-stone-200 bg-white/92 p-6 text-center shadow-[0_16px_40px_rgba(15,23,42,0.07)]">
              <div class="mx-auto h-24 w-24 overflow-hidden rounded-full border-4 border-emerald-100 shadow-[0_18px_32px_rgba(16,185,129,0.16)]">
                <img
                  src="/头像.png"
                  alt="晨熠的头像"
                  class="h-full w-full object-cover"
                />
              </div>
              <h2 class="mt-4 text-2xl font-semibold text-slate-900">晨熠 <span class="text-amber-300">✦</span></h2>
              <p class="mt-3 text-sm leading-7 text-slate-600">
                分类不是为了把内容关进盒子，而是为了更快找到下一条值得深入的线索。
              </p>

              <div class="mt-6 grid grid-cols-3 gap-3 text-center">
                <div>
                  <div class="text-xs text-slate-400">文章</div>
                  <div class="mt-1 text-2xl font-semibold text-slate-900">{posts.length}</div>
                </div>
                <div>
                  <div class="text-xs text-slate-400">标签</div>
                  <div class="mt-1 text-2xl font-semibold text-slate-900">{new Set(posts.flatMap((post) => post.data.tags)).size}</div>
                </div>
                <div>
                  <div class="text-xs text-slate-400">分类</div>
                  <div class="mt-1 text-2xl font-semibold text-slate-900">{categories.length}</div>
                </div>
              </div>

              <a
                href="https://github.com/rain1andsnow2a"
                target="_blank"
                rel="noopener noreferrer"
                class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-2xl bg-slate-900 px-4 py-3 font-medium text-white transition-colors hover:bg-slate-800"
              >
                <LocalIcon name="github" class="h-4 w-4" />
                GitHub
                <LocalIcon name="chevron-right" class="h-4 w-4" />
              </a>
            </section>

            <section class="rounded-[1.4rem] border border-stone-200 bg-white/90 p-5 shadow-[0_12px_30px_rgba(15,23,42,0.05)]">
              <h3 class="flex items-center gap-2 text-base font-semibold text-slate-800">
                <LocalIcon name="compass" class="h-4 w-4 text-slate-500" />
                快速导航
              </h3>
              <div class="mt-4 flex flex-wrap gap-2">
                {categories.slice(0, 5).map(([category, _items], index) => {
                  const meta = getCategoryMeta(category, index);
                  return (
                    <a
                      href={`/categories/${encodeURIComponent(category)}`}
                      class={`rounded-full px-3 py-1.5 text-sm font-medium ${meta.soft} ${meta.accent}`}
                    >
                      {category}
                    </a>
                  );
                })}
              </div>
            </section>
          </aside>
        </div>
      </div>
    </section>

    <aside class="category-tune-panel" id="category-tune-panel" aria-label="分类页顶部调参面板">
      <div class="category-tune-panel__header" id="category-tune-drag-handle">
        <div>
          <p class="category-tune-panel__eyebrow">Category Tuning</p>
          <h2>分类页字体调节</h2>
        </div>
        <span aria-hidden="true">拖动</span>
      </div>

      <label class="category-tune-field">
        <span>标题字体</span>
        <select id="category-title-font-control">
          <option value="sans">清爽黑体</option>
          <option value="serif">宋体书卷</option>
          <option value="brush">手写行草</option>
          <option value="playful">趣味艺术</option>
          <option value="mono">技术等宽</option>
        </select>
      </label>

      <label class="category-tune-field">
        <span>标题字号 <b id="category-title-size-value">48px</b></span>
        <input id="category-title-size-control" type="range" min="34" max="76" value="48" />
      </label>

      <label class="category-tune-field">
        <span>标题字距 <b id="category-title-letter-value">0em</b></span>
        <input id="category-title-letter-control" type="range" min="0" max="12" value="0" />
      </label>

      <label class="category-tune-field">
        <span>标题颜色</span>
        <input id="category-title-color-control" type="color" value="#0f172a" />
      </label>

      <label class="category-tune-field">
        <span>说明字体</span>
        <select id="category-copy-font-control">
          <option value="sans">清爽黑体</option>
          <option value="serif">宋体书卷</option>
          <option value="brush">手写行草</option>
          <option value="mono">技术等宽</option>
        </select>
      </label>

      <label class="category-tune-field">
        <span>说明字号 <b id="category-copy-size-value">18px</b></span>
        <input id="category-copy-size-control" type="range" min="13" max="30" value="18" />
      </label>

      <label class="category-tune-field">
        <span>说明行距 <b id="category-copy-line-value">1.63</b></span>
        <input id="category-copy-line-control" type="range" min="120" max="230" value="163" />
      </label>

      <label class="category-tune-field">
        <span>说明颜色</span>
        <input id="category-copy-color-control" type="color" value="#475569" />
      </label>

      <label class="category-tune-field">
        <span>胶囊字号 <b id="category-badge-size-value">14px</b></span>
        <input id="category-badge-size-control" type="range" min="11" max="22" value="14" />
      </label>

      <label class="category-tune-field">
        <span>卡片标题字号 <b id="category-card-title-size-value">18px</b></span>
        <input id="category-card-title-size-control" type="range" min="14" max="28" value="18" />
      </label>

      <label class="category-tune-field">
        <span>实时生成 Prompt</span>
        <textarea id="category-prompt-output" rows="5" readonly></textarea>
      </label>
    </aside>
  </main>
  <Footer />
</BaseLayout>

<style>
  .category-tune-surface {
    --category-title-size: 48px;
    --category-title-color: #0f172a;
    --category-title-letter-spacing: 0em;
    --category-copy-size: 18px;
    --category-copy-line-height: 1.63;
    --category-copy-color: #475569;
    --category-copy-letter-spacing: 0em;
    --category-badge-size: 14px;
    --category-card-title-size: 18px;
    --category-card-desc-size: 14px;
  }

  .category-hero-badge {
    color: #047857;
    font-size: var(--category-badge-size);
  }

  .category-hero-title {
    margin-top: 1.25rem;
    color: var(--category-title-color);
    font-size: var(--category-title-size);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: var(--category-title-letter-spacing);
    overflow-wrap: anywhere;
  }

  .category-hero-copy {
    max-width: 42rem;
    margin-top: 1rem;
    color: var(--category-copy-color);
    font-size: var(--category-copy-size);
    line-height: var(--category-copy-line-height);
    letter-spacing: var(--category-copy-letter-spacing);
    overflow-wrap: anywhere;
  }

  .category-hero-rule {
    width: 6rem;
    height: 0.125rem;
    margin-top: 1.25rem;
    border-radius: 999px;
    background: #10b981;
  }

  .category-card-title {
    font-size: var(--category-card-title-size);
  }

  .category-card-desc {
    font-size: var(--category-card-desc-size);
  }

  .category-tune-surface[data-category-title-font='sans'] .category-hero-title,
  .category-tune-surface[data-category-copy-font='sans'] .category-hero-copy,
  .category-tune-surface[data-category-badge-font='sans'] .category-hero-badge,
  .category-tune-surface[data-category-card-font='sans'] .category-card {
    font-family: 'Noto Sans SC', system-ui, sans-serif;
  }

  .category-tune-surface[data-category-title-font='serif'] .category-hero-title,
  .category-tune-surface[data-category-copy-font='serif'] .category-hero-copy,
  .category-tune-surface[data-category-badge-font='serif'] .category-hero-badge,
  .category-tune-surface[data-category-card-font='serif'] .category-card {
    font-family: 'Noto Serif SC', 'Noto Sans SC', serif;
  }

  .category-tune-surface[data-category-title-font='brush'] .category-hero-title,
  .category-tune-surface[data-category-copy-font='brush'] .category-hero-copy,
  .category-tune-surface[data-category-badge-font='brush'] .category-hero-badge,
  .category-tune-surface[data-category-card-font='brush'] .category-card {
    font-family: 'Ma Shan Zheng', 'Noto Serif SC', cursive;
  }

  .category-tune-surface[data-category-title-font='playful'] .category-hero-title,
  .category-tune-surface[data-category-card-font='playful'] .category-card {
    font-family: 'ZCOOL KuaiLe', 'Noto Sans SC', cursive;
  }

  .category-tune-surface[data-category-title-font='mono'] .category-hero-title,
  .category-tune-surface[data-category-copy-font='mono'] .category-hero-copy,
  .category-tune-surface[data-category-badge-font='mono'] .category-hero-badge,
  .category-tune-surface[data-category-card-font='mono'] .category-card {
    font-family: 'JetBrains Mono', 'Noto Sans SC', monospace;
  }

  .category-tune-panel {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 60;
    width: min(23rem, calc(100vw - 2rem));
    max-height: min(76vh, 42rem);
    overflow: auto;
    border: 1px solid rgba(226, 232, 240, 0.9);
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.18);
    backdrop-filter: blur(18px);
    padding: 1rem;
  }

  .category-tune-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
    cursor: grab;
    user-select: none;
  }

  .category-tune-panel__header:active {
    cursor: grabbing;
  }

  .category-tune-panel__header span {
    flex: 0 0 auto;
    border-radius: 999px;
    background: #ecfdf5;
    color: #059669;
    padding: 0.3rem 0.55rem;
    font-size: 0.72rem;
    font-weight: 800;
  }

  .category-tune-panel__eyebrow {
    margin: 0 0 0.18rem;
    color: #059669;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .category-tune-panel h2 {
    margin: 0;
    color: #0f172a;
    font-size: 1rem;
    font-weight: 800;
  }

  .category-tune-field {
    display: grid;
    gap: 0.42rem;
    color: #334155;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .category-tune-field + .category-tune-field {
    margin-top: 0.78rem;
  }

  .category-tune-field span {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .category-tune-field b {
    color: #059669;
    font-weight: 800;
  }

  .category-tune-field input,
  .category-tune-field select,
  .category-tune-field textarea {
    width: 100%;
    border: 1px solid #e2e8f0;
    border-radius: 0.85rem;
    background: #fff;
    color: #0f172a;
    padding: 0.6rem 0.7rem;
    outline: none;
  }

  .category-tune-field input[type='range'] {
    padding: 0;
    accent-color: #10b981;
  }

  .category-tune-field input[type='color'] {
    height: 2.45rem;
    padding: 0.25rem;
  }

  .category-tune-field textarea {
    min-height: 6.2rem;
    resize: vertical;
    font-family: 'JetBrains Mono', 'Noto Sans SC', monospace;
    font-size: 0.75rem;
    line-height: 1.55;
  }

  @media (max-width: 768px) {
    .category-hero-title {
      font-size: clamp(2.5rem, 14vw, var(--category-title-size));
    }

    .category-tune-panel {
      right: 0.75rem;
      bottom: 0.75rem;
      width: calc(100vw - 1.5rem);
      max-height: 56vh;
      border-radius: 1rem;
    }
  }
</style>

<script>
  const categorySurface = document.querySelector('.category-tune-surface');
  const categoryPromptOutput = document.getElementById('category-prompt-output');
  const categoryFontControls = [
    ['category-title-font-control', 'categoryTitleFont', '标题字体'],
    ['category-copy-font-control', 'categoryCopyFont', '说明字体'],
  ];
  const categoryControls = [
    ['category-title-size-control', 'category-title-size-value', '--category-title-size', 'px', '标题字号'],
    ['category-title-letter-control', 'category-title-letter-value', '--category-title-letter-spacing', 'em', '标题字距'],
    ['category-copy-size-control', 'category-copy-size-value', '--category-copy-size', 'px', '说明字号'],
    ['category-copy-line-control', 'category-copy-line-value', '--category-copy-line-height', '', '说明行距'],
    ['category-badge-size-control', 'category-badge-size-value', '--category-badge-size', 'px', '胶囊字号'],
    ['category-card-title-size-control', 'category-card-title-size-value', '--category-card-title-size', 'px', '卡片标题字号'],
  ];

  const categoryFontNames = {
    sans: '清爽黑体',
    serif: '宋体书卷',
    brush: '手写行草',
    playful: '趣味艺术',
    mono: '技术等宽',
  };

  function formatCategoryValue(controlId, rawValue) {
    if (controlId === 'category-copy-line-control') return (Number(rawValue) / 100).toFixed(2);
    if (controlId === 'category-title-letter-control') return (Number(rawValue) / 100).toFixed(2);
    return rawValue;
  }

  function updateCategoryTunePanel() {
    if (!(categorySurface instanceof HTMLElement)) return;

    const promptParts = [];

    categoryFontControls.forEach(([controlId, datasetKey, label]) => {
      const control = document.getElementById(controlId);
      if (!(control instanceof HTMLSelectElement)) return;
      categorySurface.dataset[datasetKey] = control.value;
      promptParts.push(`${label} ${categoryFontNames[control.value] ?? control.value}`);
    });

    categoryControls.forEach(([controlId, valueId, cssVar, unit, label]) => {
      const control = document.getElementById(controlId);
      const value = document.getElementById(valueId);

      if (!(control instanceof HTMLInputElement)) return;

      const formatted = formatCategoryValue(controlId, control.value);
      const nextValue = `${formatted}${unit}`;
      categorySurface.style.setProperty(cssVar, nextValue);
      if (value) value.textContent = nextValue;
      promptParts.push(`${label} ${nextValue}`);
    });

    const titleColorControl = document.getElementById('category-title-color-control');
    if (titleColorControl instanceof HTMLInputElement) {
      categorySurface.style.setProperty('--category-title-color', titleColorControl.value);
      promptParts.push(`标题颜色 ${titleColorControl.value}`);
    }

    const copyColorControl = document.getElementById('category-copy-color-control');
    if (copyColorControl instanceof HTMLInputElement) {
      categorySurface.style.setProperty('--category-copy-color', copyColorControl.value);
      promptParts.push(`说明颜色 ${copyColorControl.value}`);
    }

    if (categoryPromptOutput instanceof HTMLTextAreaElement) {
      categoryPromptOutput.value = `请把分类页顶部区域调整为：${promptParts.join('，')}。保持移动端单列排版，按钮不换行溢出，头像卡不挤压正文；如果确认这些参数，请固化样式并删除调参面板。`;
    }
  }

  [...categoryFontControls, ...categoryControls].forEach(([controlId]) => {
    const control = document.getElementById(controlId);
    control?.addEventListener('input', updateCategoryTunePanel);
    control?.addEventListener('change', updateCategoryTunePanel);
  });
  document.getElementById('category-title-color-control')?.addEventListener('input', updateCategoryTunePanel);
  document.getElementById('category-copy-color-control')?.addEventListener('input', updateCategoryTunePanel);
  updateCategoryTunePanel();

  const tunePanel = document.getElementById('category-tune-panel');
  const dragHandle = document.getElementById('category-tune-drag-handle');
  let dragState = null;

  function clampPanelPosition(left, top) {
    if (!(tunePanel instanceof HTMLElement)) return { left, top };

    const rect = tunePanel.getBoundingClientRect();
    const margin = 12;
    return {
      left: Math.min(Math.max(margin, left), window.innerWidth - rect.width - margin),
      top: Math.min(Math.max(margin, top), window.innerHeight - rect.height - margin),
    };
  }

  dragHandle?.addEventListener('pointerdown', (event) => {
    if (!(tunePanel instanceof HTMLElement)) return;

    const rect = tunePanel.getBoundingClientRect();
    dragState = {
      offsetX: event.clientX - rect.left,
      offsetY: event.clientY - rect.top,
    };
    tunePanel.style.left = `${rect.left}px`;
    tunePanel.style.top = `${rect.top}px`;
    tunePanel.style.right = 'auto';
    tunePanel.style.bottom = 'auto';
    dragHandle.setPointerCapture(event.pointerId);
  });

  dragHandle?.addEventListener('pointermove', (event) => {
    if (!dragState || !(tunePanel instanceof HTMLElement)) return;

    const next = clampPanelPosition(event.clientX - dragState.offsetX, event.clientY - dragState.offsetY);
    tunePanel.style.left = `${next.left}px`;
    tunePanel.style.top = `${next.top}px`;
  });

  dragHandle?.addEventListener('pointerup', (event) => {
    dragState = null;
    dragHandle.releasePointerCapture(event.pointerId);
  });

  window.addEventListener('resize', () => {
    if (!(tunePanel instanceof HTMLElement) || tunePanel.style.left === '') return;

    const rect = tunePanel.getBoundingClientRect();
    const next = clampPanelPosition(rect.left, rect.top);
    tunePanel.style.left = `${next.left}px`;
    tunePanel.style.top = `${next.top}px`;
  });
</script>
