---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="文章" description="晨熠的所有博客文章">
  <Header />
  <main class="max-w-5xl mx-auto px-6 py-10 flex-1">
    <h1 class="text-2xl font-bold text-slate-100 mb-8">文章</h1>
    <div class="space-y-2">
      {posts.map((post) => {
        const formattedDate = post.data.pubDate.toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        return (
          <a
            href={`/blog/${post.id}`}
            class="group flex items-center justify-between py-4 px-4 -mx-4 rounded-lg border border-transparent hover:border-navy-700/50 hover:bg-navy-800/40 transition-all duration-300"
          >
            <div class="flex-1 min-w-0">
              <h2 class="text-slate-200 group-hover:text-amber-400 transition-colors duration-200 group-hover:translate-x-1 transform truncate">
                {post.data.title}
              </h2>
              {post.data.description && (
                <p class="text-sm text-slate-500 group-hover:text-slate-400 mt-1 line-clamp-1 transition-colors">
                  {post.data.description}
                </p>
              )}
            </div>
            <span class="text-xs text-slate-600 group-hover:text-slate-500 shrink-0 ml-4 transition-colors">
              {formattedDate}
            </span>
          </a>
        );
      })}
    </div>
    {posts.length === 0 && (
      <p class="text-slate-500 text-center py-16">暂无文章，敬请期待...</p>
    )}
  </main>
  <Footer />
</BaseLayout>
