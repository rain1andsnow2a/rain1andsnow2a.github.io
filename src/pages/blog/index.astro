---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import LocalIcon from '../../components/LocalIcon.astro';
import { getCategoryMeta } from '../../utils/categoryMeta';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const categoryMap = posts.reduce((acc, post) => {
  const key = post.data.category || '未分类';
  acc.set(key, (acc.get(key) || 0) + 1);
  return acc;
}, new Map<string, number>());

const categories = Array.from(categoryMap.entries()).sort((a, b) => b[1] - a[1]);
const coverImages = [
  '/article-cover-knowledge-01.png',
  '/article-cover-knowledge-02.png',
  '/article-cover-knowledge-03.png',
  '/article-cover-knowledge-04.png',
];
---

<BaseLayout title="文章" description="晨熠的所有博客文章">
  <Header />

  <main class="blog-archive-surface flex-1" data-card-font="serif" data-archive-copy-font="serif">
    <section class="mx-auto max-w-[1500px] px-6 pb-8 pt-6">
      <div class="relative overflow-hidden rounded-[2rem] border border-white/70 bg-[linear-gradient(135deg,#ffffff_0%,#fff9f0_48%,#f7fbff_100%)] px-8 py-10 shadow-[0_28px_70px_rgba(15,23,42,0.10)]">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(251,146,60,0.12),transparent_28%),radial-gradient(circle_at_82%_18%,rgba(56,189,248,0.10),transparent_22%)]"></div>
        <div class="relative grid gap-8 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-end">
          <div>
            <h1 class="text-5xl font-bold tracking-tight text-slate-900">文章</h1>
            <p class="archive-intro">
              把技术探索、学习札记与思考片段按时间展开。这里更像一条长长的航迹，能看到我最近在追逐什么、停留什么、又在重新理解什么。
            </p>
          </div>

          <div class="rounded-[1.8rem] border border-slate-200 bg-white/85 p-6 shadow-[0_18px_45px_rgba(15,23,42,0.08)] backdrop-blur-sm">
            <div class="grid grid-cols-2 gap-4 text-center">
              <div class="rounded-2xl bg-slate-50 px-4 py-4">
                <div class="text-3xl font-bold text-slate-900">{posts.length}</div>
                <div class="mt-1 text-sm text-slate-500">文章总数</div>
              </div>
              <div class="rounded-2xl bg-slate-50 px-4 py-4">
                <div class="text-3xl font-bold text-slate-900">{categories.length}</div>
                <div class="mt-1 text-sm text-slate-500">分类数量</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-[1500px] px-6 pb-16">
      <div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_300px]">
        <div>
          <div class="article-card-grid">
            {posts.map((post, index) => {
              const formattedDate = post.data.pubDate.toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: 'numeric',
                day: 'numeric',
              });
              const readingMinutes = Math.max(4, Math.ceil((post.body?.length || 800) / 420));
              const cover = coverImages[index % coverImages.length];

              return (
                <a
                  href={`/blog/${post.id}`}
                  class="article-card group"
                >
                  <div class="article-card-media relative overflow-hidden">
                    <img
                      src={cover}
                      alt={post.data.title}
                      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    />
                    <div class="absolute inset-0 bg-[linear-gradient(180deg,transparent_0%,rgba(15,23,42,0.6)_100%)]"></div>
                  </div>

                  <div class="article-card-body">
                    <div class="mb-2 flex flex-wrap gap-2">
                      <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-600">
                        {post.data.category}
                      </span>
                      {post.data.tags.slice(0, 2).map((tag) => (
                        <span class="rounded-full bg-sky-50 px-3 py-1 text-xs font-semibold text-sky-600">
                          {tag}
                        </span>
                      ))}
                    </div>

                    <h2 class="article-card-title transition-colors duration-200 group-hover:text-orange-500">
                      {post.data.title}
                    </h2>

                    {post.data.description && (
                      <p class="article-card-desc mt-2 line-clamp-2 leading-6">
                        {post.data.description}
                      </p>
                    )}

                    <div class="article-card-meta mt-4 flex flex-wrap items-center gap-4 text-xs text-slate-400">
                      <span class="inline-flex items-center gap-1.5">
                        <LocalIcon name="calendar-days" class="h-4 w-4" />
                        {formattedDate}
                      </span>
                      <span class="inline-flex items-center gap-1.5">
                        <LocalIcon name="clock-3" class="h-4 w-4" />
                        {readingMinutes} 分钟阅读
                      </span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>

          {posts.length === 0 && (
            <p class="rounded-[1.6rem] border border-slate-200 bg-white px-6 py-16 text-center text-slate-500 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
              暂无文章，敬请期待...
            </p>
          )}
        </div>

        <aside class="space-y-6">
          <section class="rounded-[1.7rem] border border-slate-200 bg-white p-6 shadow-[0_18px_50px_rgba(15,23,42,0.08)]">
            <h3 class="text-3xl font-semibold text-slate-900">分类总览</h3>
            <div class="mt-5 space-y-3">
              {categories.map(([name, count], index) => {
                const meta = getCategoryMeta(name, index);

                return (
                  <a
                    href={`/categories/${encodeURIComponent(name)}`}
                    class="flex items-center justify-between rounded-2xl px-3 py-3 transition-colors hover:bg-slate-50"
                  >
                    <span class="flex items-center gap-3">
                      <span class={`flex h-9 w-9 items-center justify-center rounded-xl border ${meta.soft} ${meta.accent} ${meta.ring}`}>
                        <LocalIcon name={meta.icon} class="h-4 w-4" />
                      </span>
                      <span class="text-lg font-medium text-slate-700">{name}</span>
                    </span>
                    <span class="text-lg font-semibold text-slate-400">{count}</span>
                  </a>
                );
              })}
            </div>
          </section>
        </aside>
      </div>
    </section>

    <aside class="archive-tune-panel" id="archive-tune-panel" aria-label="文章页说明文字调参面板">
      <div class="archive-tune-panel__header" id="archive-tune-drag-handle">
        <div>
          <p class="archive-tune-panel__eyebrow">Archive Copy</p>
          <h2>文章说明调节</h2>
        </div>
        <span aria-hidden="true">拖动</span>
      </div>

      <label class="archive-tune-field">
        <span>字体</span>
        <select id="archive-copy-font-control">
          <option value="serif">宋体书卷</option>
          <option value="sans">清爽黑体</option>
          <option value="brush">手写行草</option>
          <option value="mono">技术等宽</option>
        </select>
      </label>

      <label class="archive-tune-field">
        <span>字号 <b id="archive-copy-size-value">18px</b></span>
        <input id="archive-copy-size-control" type="range" min="13" max="28" value="18" />
      </label>

      <label class="archive-tune-field">
        <span>行距 <b id="archive-copy-line-value">1.78</b></span>
        <input id="archive-copy-line-control" type="range" min="120" max="230" value="178" />
      </label>

      <label class="archive-tune-field">
        <span>字距 <b id="archive-copy-letter-value">0.01em</b></span>
        <input id="archive-copy-letter-control" type="range" min="0" max="12" value="1" />
      </label>

      <label class="archive-tune-field">
        <span>颜色</span>
        <input id="archive-copy-color-control" type="color" value="#475569" />
      </label>

      <label class="archive-tune-field">
        <span>上间距 <b id="archive-copy-margin-value">16px</b></span>
        <input id="archive-copy-margin-control" type="range" min="6" max="36" value="16" />
      </label>

      <label class="archive-tune-field">
        <span>文本宽度 <b id="archive-copy-width-value">768px</b></span>
        <input id="archive-copy-width-control" type="range" min="520" max="980" value="768" />
      </label>

      <label class="archive-tune-field">
        <span>实时生成 Prompt</span>
        <textarea id="archive-prompt-output" rows="5" readonly></textarea>
      </label>
    </aside>
  </main>

  <Footer />
</BaseLayout>

<style>
  .blog-archive-surface {
    --article-card-gap: 14px;
    --article-card-width: 250px;
    --article-card-min-height: 284px;
    --article-card-image-height: 128px;
    --article-title-size: 19px;
    --article-desc-size: 12px;
    --article-card-letter-spacing: 0.01em;
    --archive-copy-size: 18px;
    --archive-copy-line-height: 1.78;
    --archive-copy-letter-spacing: 0.01em;
    --archive-copy-color: #475569;
    --archive-copy-margin-top: 16px;
    --archive-copy-max-width: 768px;
  }

  .archive-intro {
    max-width: var(--archive-copy-max-width);
    margin-top: var(--archive-copy-margin-top);
    color: var(--archive-copy-color);
    font-size: var(--archive-copy-size);
    line-height: var(--archive-copy-line-height);
    letter-spacing: var(--archive-copy-letter-spacing);
    overflow-wrap: anywhere;
  }

  .blog-archive-surface[data-archive-copy-font='serif'] .archive-intro {
    font-family: 'Noto Serif SC', 'Noto Sans SC', serif;
  }

  .blog-archive-surface[data-archive-copy-font='sans'] .archive-intro {
    font-family: 'Noto Sans SC', system-ui, sans-serif;
  }

  .blog-archive-surface[data-archive-copy-font='brush'] .archive-intro {
    font-family: 'Ma Shan Zheng', 'Noto Serif SC', cursive;
  }

  .blog-archive-surface[data-archive-copy-font='mono'] .archive-intro {
    font-family: 'JetBrains Mono', 'Noto Sans SC', monospace;
  }

  .article-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, var(--article-card-width)), 1fr));
    gap: var(--article-card-gap);
  }

  .article-card {
    display: flex;
    min-height: var(--article-card-min-height);
    overflow: hidden;
    flex-direction: column;
    border: 1px solid rgb(226 232 240);
    border-radius: 1rem;
    background: #fff;
    box-shadow: 0 14px 36px rgba(15, 23, 42, 0.07);
    letter-spacing: var(--article-card-letter-spacing);
    transition:
      transform 300ms ease,
      box-shadow 300ms ease;
  }

  .article-card:hover {
    transform: translateY(-0.25rem);
    box-shadow: 0 22px 48px rgba(15, 23, 42, 0.1);
  }

  .article-card-media {
    height: var(--article-card-image-height);
    flex: 0 0 var(--article-card-image-height);
  }

  .article-card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 1rem 1.25rem 1.25rem;
  }

  .article-card-title {
    color: #0f172a;
    font-size: var(--article-title-size);
    font-weight: 700;
    line-height: 1.32;
    overflow-wrap: anywhere;
  }

  .article-card-desc {
    color: #64748b;
    font-size: var(--article-desc-size);
    overflow-wrap: anywhere;
  }

  .article-card-meta {
    margin-top: auto;
    padding-top: 1rem;
  }

  .blog-archive-surface[data-card-font='serif'] .article-card {
    font-family: 'Noto Serif SC', 'Noto Sans SC', serif;
  }

  .archive-tune-panel {
    position: fixed;
    right: 1.25rem;
    bottom: 1.25rem;
    z-index: 60;
    width: min(23rem, calc(100vw - 2rem));
    max-height: min(76vh, 42rem);
    overflow: auto;
    border: 1px solid rgba(226, 232, 240, 0.9);
    border-radius: 1.25rem;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.18);
    backdrop-filter: blur(18px);
    padding: 1rem;
  }

  .archive-tune-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.85rem;
    cursor: grab;
    user-select: none;
  }

  .archive-tune-panel__header:active {
    cursor: grabbing;
  }

  .archive-tune-panel__header span {
    flex: 0 0 auto;
    border-radius: 999px;
    background: #fff7ed;
    color: #f97316;
    padding: 0.3rem 0.55rem;
    font-size: 0.72rem;
    font-weight: 800;
  }

  .archive-tune-panel__eyebrow {
    margin: 0 0 0.18rem;
    color: #f97316;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .archive-tune-panel h2 {
    margin: 0;
    color: #0f172a;
    font-size: 1rem;
    font-weight: 800;
  }

  .archive-tune-field {
    display: grid;
    gap: 0.42rem;
    color: #334155;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .archive-tune-field + .archive-tune-field {
    margin-top: 0.78rem;
  }

  .archive-tune-field span {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .archive-tune-field b {
    color: #f97316;
    font-weight: 800;
  }

  .archive-tune-field input,
  .archive-tune-field select,
  .archive-tune-field textarea {
    width: 100%;
    border: 1px solid #e2e8f0;
    border-radius: 0.85rem;
    background: #fff;
    color: #0f172a;
    padding: 0.6rem 0.7rem;
    outline: none;
  }

  .archive-tune-field input[type='range'] {
    padding: 0;
    accent-color: #f97316;
  }

  .archive-tune-field input[type='color'] {
    height: 2.45rem;
    padding: 0.25rem;
  }

  .archive-tune-field textarea {
    min-height: 6.2rem;
    resize: vertical;
    font-family: 'JetBrains Mono', 'Noto Sans SC', monospace;
    font-size: 0.75rem;
    line-height: 1.55;
  }

  @media (max-width: 768px) {
    .article-card-grid {
      grid-template-columns: 1fr;
    }

    .archive-tune-panel {
      right: 0.75rem;
      bottom: 0.75rem;
      width: calc(100vw - 1.5rem);
      max-height: 56vh;
      border-radius: 1rem;
    }
  }
</style>

<script>
  const archiveSurface = document.querySelector('.blog-archive-surface');
  const archivePromptOutput = document.getElementById('archive-prompt-output');
  const archiveFontControl = document.getElementById('archive-copy-font-control');
  const archiveControls = [
    ['archive-copy-size-control', 'archive-copy-size-value', '--archive-copy-size', 'px', '字号'],
    ['archive-copy-line-control', 'archive-copy-line-value', '--archive-copy-line-height', '', '行距'],
    ['archive-copy-letter-control', 'archive-copy-letter-value', '--archive-copy-letter-spacing', 'em', '字距'],
    ['archive-copy-margin-control', 'archive-copy-margin-value', '--archive-copy-margin-top', 'px', '上间距'],
    ['archive-copy-width-control', 'archive-copy-width-value', '--archive-copy-max-width', 'px', '文本宽度'],
  ];

  const archiveFontNames = {
    serif: '宋体书卷',
    sans: '清爽黑体',
    brush: '手写行草',
    mono: '技术等宽',
  };

  function formatArchiveControlValue(controlId, rawValue) {
    if (controlId === 'archive-copy-line-control') return (Number(rawValue) / 100).toFixed(2);
    if (controlId === 'archive-copy-letter-control') return (Number(rawValue) / 100).toFixed(2);
    return rawValue;
  }

  function updateArchiveTunePanel() {
    if (!(archiveSurface instanceof HTMLElement)) return;

    const promptParts = [];

    if (archiveFontControl instanceof HTMLSelectElement) {
      archiveSurface.dataset.archiveCopyFont = archiveFontControl.value;
      promptParts.push(`字体 ${archiveFontNames[archiveFontControl.value] ?? archiveFontControl.value}`);
    }

    archiveControls.forEach(([controlId, valueId, cssVar, unit, label]) => {
      const control = document.getElementById(controlId);
      const value = document.getElementById(valueId);

      if (!(control instanceof HTMLInputElement)) return;

      const formatted = formatArchiveControlValue(controlId, control.value);
      const nextValue = `${formatted}${unit}`;
      archiveSurface.style.setProperty(cssVar, nextValue);
      if (value) value.textContent = nextValue;
      promptParts.push(`${label} ${nextValue}`);
    });

    const colorControl = document.getElementById('archive-copy-color-control');
    if (colorControl instanceof HTMLInputElement) {
      archiveSurface.style.setProperty('--archive-copy-color', colorControl.value);
      promptParts.push(`颜色 ${colorControl.value}`);
    }

    if (archivePromptOutput instanceof HTMLTextAreaElement) {
      archivePromptOutput.value = `请把文章页顶部说明文字调整为：${promptParts.join('，')}。保持已删除的火焰图标与 ARCHIVE 胶囊不要恢复；继续保证移动端单列排版、按钮不换行溢出、头像卡不挤压正文。`;
    }
  }

  archiveFontControl?.addEventListener('change', updateArchiveTunePanel);
  archiveControls.forEach(([controlId]) => {
    const control = document.getElementById(controlId);
    control?.addEventListener('input', updateArchiveTunePanel);
    control?.addEventListener('change', updateArchiveTunePanel);
  });
  document.getElementById('archive-copy-color-control')?.addEventListener('input', updateArchiveTunePanel);
  updateArchiveTunePanel();

  const tunePanel = document.getElementById('archive-tune-panel');
  const dragHandle = document.getElementById('archive-tune-drag-handle');
  let dragState = null;

  function clampPanelPosition(left, top) {
    if (!(tunePanel instanceof HTMLElement)) return { left, top };

    const rect = tunePanel.getBoundingClientRect();
    const margin = 12;
    return {
      left: Math.min(Math.max(margin, left), window.innerWidth - rect.width - margin),
      top: Math.min(Math.max(margin, top), window.innerHeight - rect.height - margin),
    };
  }

  dragHandle?.addEventListener('pointerdown', (event) => {
    if (!(tunePanel instanceof HTMLElement)) return;

    const rect = tunePanel.getBoundingClientRect();
    dragState = {
      offsetX: event.clientX - rect.left,
      offsetY: event.clientY - rect.top,
    };
    tunePanel.style.left = `${rect.left}px`;
    tunePanel.style.top = `${rect.top}px`;
    tunePanel.style.right = 'auto';
    tunePanel.style.bottom = 'auto';
    dragHandle.setPointerCapture(event.pointerId);
  });

  dragHandle?.addEventListener('pointermove', (event) => {
    if (!dragState || !(tunePanel instanceof HTMLElement)) return;

    const next = clampPanelPosition(event.clientX - dragState.offsetX, event.clientY - dragState.offsetY);
    tunePanel.style.left = `${next.left}px`;
    tunePanel.style.top = `${next.top}px`;
  });

  dragHandle?.addEventListener('pointerup', (event) => {
    dragState = null;
    dragHandle.releasePointerCapture(event.pointerId);
  });

  window.addEventListener('resize', () => {
    if (!(tunePanel instanceof HTMLElement) || tunePanel.style.left === '') return;

    const rect = tunePanel.getBoundingClientRect();
    const next = clampPanelPosition(rect.left, rect.top);
    tunePanel.style.left = `${next.left}px`;
    tunePanel.style.top = `${next.top}px`;
  });
</script>
