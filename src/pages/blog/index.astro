---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="文章" description="晨熠的所有博客文章">
  <Header />
  <main class="max-w-5xl mx-auto px-6 py-10 flex-1">
    <h1 class="text-2xl font-bold text-slate-100 mb-8">文章</h1>
    <div class="space-y-3">
      {posts.map((post) => {
        const formattedDate = post.data.pubDate.toLocaleDateString('zh-CN', {
          year: 'numeric',
          month: 'short',
          day: 'numeric',
        });
        return (
          <a
            href={`/blog/${post.id}`}
            class="group block py-5 px-5 -mx-2 rounded-xl border border-navy-700/30 bg-navy-800/20 hover:border-amber-400/30 hover:bg-navy-800/50 transition-all duration-300"
          >
            <div class="flex items-start justify-between gap-4">
              <div class="flex-1 min-w-0">
                <h2 class="text-lg text-slate-200 font-medium group-hover:text-amber-400 transition-colors duration-200 truncate">
                  {post.data.title}
                </h2>
                {post.data.description && (
                  <p class="text-sm text-slate-500 group-hover:text-slate-400 mt-1.5 line-clamp-2 transition-colors leading-relaxed">
                    {post.data.description}
                  </p>
                )}
                <div class="flex flex-wrap items-center gap-2 mt-3">
                  <span class="text-xs text-slate-600 group-hover:text-slate-500 transition-colors">
                    {formattedDate}
                  </span>
                  {post.data.tags.length > 0 && (
                    <span class="text-navy-700">·</span>
                  )}
                  {post.data.tags.map((tag) => (
                    <span class="px-2 py-0.5 text-[11px] font-medium bg-amber-400/8 text-amber-400/80 rounded-full border border-amber-400/15">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
              <span class="text-slate-600 group-hover:text-amber-400/60 shrink-0 mt-1 transition-colors">
                →
              </span>
            </div>
          </a>
        );
      })}
    </div>
    {posts.length === 0 && (
      <p class="text-slate-500 text-center py-16">暂无文章，敬请期待...</p>
    )}
  </main>
  <Footer />
</BaseLayout>
