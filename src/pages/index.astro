    line-height: 1.15;
  }

  .category-list {
    display: grid;
    gap: var(--category-list-gap);
    margin-top: 1.25rem;
  }

  .category-item {
    padding: var(--category-item-y) var(--category-item-x);
  }

  .category-icon {
