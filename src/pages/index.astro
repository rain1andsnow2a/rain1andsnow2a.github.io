</style>

<script>
  const typedTarget = document.getElementById('hero-typed');
  const caret = document.querySelector('.typewriter-caret');

  function runTypewriter() {
    if (!typedTarget) return;

    const fullText = typedTarget.getAttribute('data-text') ?? '';
    typedTarget.textContent = '';

    if (!fullText) {
      if (caret instanceof HTMLElement) caret.style.display = 'none';
      return;
    }

    let index = 0;
    const typeNext = () => {
      index += 1;
      typedTarget.textContent = fullText.slice(0, index);

      if (index < fullText.length) {
        window.setTimeout(typeNext, index < 8 ? 95 : 50);
      }
    };

    window.setTimeout(typeNext, 500);
  }

  runTypewriter();

  const sideSurface = document.getElementById('home-design-surface');
  const sideControls = [
    ['side-panel-padding-control', 'side-panel-padding-value', '--side-panel-padding', 'px', '面板内距'],
    ['side-title-size-control', 'side-title-size-value', '--side-title-size', 'px', '标题字号'],
    ['category-gap-control', 'category-gap-value', '--category-list-gap', 'px', '分类间距'],
    ['category-y-control', 'category-y-value', '--category-item-y', 'px', '分类上下内距'],
    ['category-text-size-control', 'category-text-size-value', '--category-text-size', 'px', '分类文字字号'],
    ['category-icon-size-control', 'category-icon-size-value', '--category-icon-size', 'px', '分类图标尺寸'],
    ['tag-gap-control', 'tag-gap-value', '--tag-cloud-gap', 'px', '标签间距'],
    ['tag-x-control', 'tag-x-value', '--tag-pill-x', 'px', '标签左右内距'],
    ['tag-font-size-control', 'tag-font-size-value', '--tag-font-size', 'px', '标签文字字号'],
  ];
  const sidePromptOutput = document.getElementById('side-prompt-output');

  function updateSideTunePanel() {
    if (!(sideSurface instanceof HTMLElement)) return;

    const promptParts = [];

    sideControls.forEach(([controlId, valueId, cssVar, unit, label]) => {
      const control = document.getElementById(controlId);
      const value = document.getElementById(valueId);

      if (!(control instanceof HTMLInputElement)) return;

      const nextValue = `${control.value}${unit}`;
      sideSurface.style.setProperty(cssVar, nextValue);
      if (value) value.textContent = nextValue;
      promptParts.push(`${label} ${nextValue}`);
    });

    if (sidePromptOutput instanceof HTMLTextAreaElement) {
      sidePromptOutput.value = `请把首页侧栏的分类与标签云调整为：${promptParts.join('，')}。尤其保持分类条目之间的距离清晰可控；继续保证移动端单列排版、按钮不换行溢出、头像卡不挤压正文，并且不要恢复英文标语和多余装饰符号。`;
    }
  }

  sideControls.forEach(([controlId]) => {
    const control = document.getElementById(controlId);
    control?.addEventListener('input', updateSideTunePanel);
    control?.addEventListener('change', updateSideTunePanel);
  });

  updateSideTunePanel();
</script>
