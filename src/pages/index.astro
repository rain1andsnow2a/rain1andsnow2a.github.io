  }

  .tag-cloud {
    gap: var(--tag-cloud-gap);
    margin-top: 1.25rem;
  }

  .tag-pill {
    padding: var(--tag-pill-y) var(--tag-pill-x);
    font-size: var(--tag-font-size);
