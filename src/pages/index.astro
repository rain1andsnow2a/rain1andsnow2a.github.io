---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const recentPosts = posts.slice(0, 5);
---

<BaseLayout title="首页" description="晨熠的个人博客 - 深空中的丁火">
  <Header />
  <main class="flex-1">
    <!-- Hero 区域 - 带深空背景 -->
    <section id="hero" class="relative overflow-hidden min-h-[70vh] flex items-center">
      <!-- 背景图片 - 视差层 -->
      <div id="hero-bg" class="absolute inset-0 will-change-transform">
        <img
          src="/hero-bg-new_1.png"
          alt="深空星夜"
          class="w-full h-full object-cover scale-110"
        />
        <!-- 极轻遮罩，只保留底部过渡 -->
       
      </div>

      <!-- Canvas 流星动画层 -->
      <canvas id="meteor-canvas" class="absolute inset-0 pointer-events-none"></canvas>

      <!-- CSS 星空粒子层 -->
      <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="stars-layer"></div>
        <div class="stars-layer stars-layer-2"></div>
      </div>

      <!-- Hero 内容 -->
      <div class="relative max-w-5xl mx-auto px-6 py-24 sm:py-32 w-full">
        <div class="flex items-start justify-between gap-8">
          <!-- 左侧文字 -->
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-4 hero-fade-in">
              <Icon name="lucide:sparkles" class="w-10 h-10 text-amber-400 drop-shadow-[0_0_12px_rgba(251,191,36,0.5)] animate-pulse-slow" />
              <h1 class="text-5xl sm:text-6xl font-bold text-slate-100 drop-shadow-lg">晨熠</h1>
            </div>
            <p class="text-xl sm:text-2xl text-slate-200 mb-3 font-light hero-fade-in hero-delay-1 drop-shadow-md">
              深空中的丁火 · 寒夜里的极光
            </p>
            <p class="text-slate-300/90 leading-relaxed max-w-2xl hero-fade-in hero-delay-2 drop-shadow-sm">
              <span
                id="hero-typed"
                class="typewriter-copy"
                data-text="记录技术探索、思考与成长。在广袤的信息宇宙中，这里是一颗安静燃烧的星。"
              ></span>
              <span class="typewriter-caret" aria-hidden="true"></span>
            </p>
          </div>

          <!-- 右侧头像 -->
          <div class="hidden sm:flex flex-col items-center hero-fade-in hero-delay-1">
            <div class="avatar-wrapper relative">
              <div class="avatar-glow"></div>
              <img
                src="/头像.png"
                alt="晨熠的头像"
                class="avatar-img relative w-32 h-32 lg:w-40 lg:h-40 rounded-full object-cover border-2 border-amber-400/40 shadow-xl"
              />
            </div>
            <span class="mt-3 text-sm text-slate-400/80 font-light tracking-wide">Explorer & Dreamer</span>
          </div>
        </div>
      </div>
    </section>

    <!-- 最近文章 -->
    <section class="max-w-5xl mx-auto px-6 py-12">
      <div class="flex items-center justify-between mb-8">
        <h2 class="text-xl font-semibold text-slate-800 flex items-center gap-2">
          <Icon name="lucide:book-open" class="w-5 h-5 text-sky-500" />
          最近文章
        </h2>
        <a href="/blog" class="group text-sm text-amber-600 hover:text-amber-500 transition-colors flex items-center gap-1">
          查看全部
          <Icon name="lucide:arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200" />
        </a>
      </div>
      <div class="space-y-3">
        {recentPosts.map((post) => {
          const formattedDate = post.data.pubDate.toLocaleDateString('zh-CN', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
          });
          return (
            <a
              href={`/blog/${post.id}`}
              class="group relative flex items-center justify-between gap-6 overflow-hidden rounded-2xl border border-stone-200 bg-gradient-to-r from-white via-white to-sky-50/70 px-5 py-4 shadow-[0_18px_40px_rgba(148,163,184,0.10)] transition-all duration-300 hover:-translate-y-0.5 hover:border-sky-300/55 hover:shadow-[0_22px_52px_rgba(56,189,248,0.14)]"
            >
              <span class="pointer-events-none absolute inset-y-3 left-0 w-px bg-gradient-to-b from-transparent via-sky-300/70 to-transparent opacity-70 transition-opacity duration-300 group-hover:opacity-100"></span>
              <span class="min-w-0 flex items-center gap-3">
                <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-sky-300/30 bg-sky-100/80 text-sky-600 transition-colors duration-300 group-hover:border-sky-300/45 group-hover:bg-sky-100 group-hover:text-sky-700">
                  <Icon name="lucide:file-text" class="h-4 w-4" />
                </span>
                <span class="truncate text-base text-slate-700 transition-all duration-200 group-hover:text-slate-900 group-hover:translate-x-1">
                  {post.data.title}
                </span>
              </span>
              <span class="shrink-0 rounded-full border border-amber-300/40 bg-amber-50 px-3 py-1 text-xs font-medium tracking-wide text-amber-700 transition-colors duration-300 group-hover:border-amber-400/45 group-hover:bg-amber-100/80 group-hover:text-amber-800">
                {formattedDate}
              </span>
            </a>
          );
        })}
      </div>
    </section>

    <!-- 关于我 -->
    <section class="max-w-5xl mx-auto px-6 mt-8 pt-8 border-t border-stone-200 pb-16">
      <h2 class="text-xl font-semibold text-slate-800 mb-4 flex items-center gap-2">
        <Icon name="lucide:user" class="w-5 h-5 text-emerald-500" />
        关于
      </h2>
      <div class="max-w-2xl space-y-3 rounded-3xl border border-stone-200/80 bg-white/75 px-6 py-6 text-slate-600 leading-relaxed shadow-[0_18px_40px_rgba(148,163,184,0.08)] backdrop-blur-sm">
        <p>
          我是晨熠，一个热爱技术的探索者。这个博客是我的数字花园，记录学习路上的点滴收获。
        </p>
        <div class="flex gap-4 text-sm">
          <a
            href="https://github.com/rain1andsnow2a"
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center gap-1.5 text-slate-500 hover:text-slate-800 transition-colors"
          >
            <Icon name="lucide:github" class="w-4 h-4" />
            GitHub
            <Icon name="lucide:arrow-right" class="w-3 h-3 group-hover:translate-x-1 transition-transform duration-200" />
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  /* 星空粒子动画 - 增强版 */
  .stars-layer {
    position: absolute;
    width: 100%;
    height: 100%;
    background-image:
      radial-gradient(2px 2px at 10% 20%, rgba(255, 255, 255, 0.9) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 30% 60%, rgba(255, 255, 255, 0.8) 50%, transparent 100%),
      radial-gradient(2.5px 2.5px at 50% 10%, rgba(251, 191, 36, 0.9) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 70% 40%, rgba(255, 255, 255, 0.7) 50%, transparent 100%),
      radial-gradient(2px 2px at 90% 70%, rgba(255, 255, 255, 0.85) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 15% 80%, rgba(100, 200, 255, 0.6) 50%, transparent 100%),
      radial-gradient(2.5px 2.5px at 85% 15%, rgba(251, 191, 36, 0.7) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 45% 90%, rgba(255, 255, 255, 0.75) 50%, transparent 100%),
      radial-gradient(1px 1px at 25% 35%, rgba(255, 255, 255, 0.6) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 60% 75%, rgba(100, 200, 255, 0.5) 50%, transparent 100%),
      radial-gradient(2px 2px at 5% 55%, rgba(255, 255, 255, 0.8) 50%, transparent 100%),
      radial-gradient(1px 1px at 75% 25%, rgba(251, 191, 36, 0.6) 50%, transparent 100%);
    animation: twinkle 3s ease-in-out infinite alternate;
  }

  .stars-layer-2 {
    background-image:
      radial-gradient(1.5px 1.5px at 20% 50%, rgba(255, 255, 255, 0.8) 50%, transparent 100%),
      radial-gradient(2px 2px at 60% 30%, rgba(255, 255, 255, 0.85) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 80% 80%, rgba(100, 200, 255, 0.6) 50%, transparent 100%),
      radial-gradient(2.5px 2.5px at 40% 70%, rgba(251, 191, 36, 0.7) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 5% 45%, rgba(255, 255, 255, 0.9) 50%, transparent 100%),
      radial-gradient(2px 2px at 95% 55%, rgba(255, 255, 255, 0.75) 50%, transparent 100%),
      radial-gradient(1px 1px at 35% 15%, rgba(100, 200, 255, 0.5) 50%, transparent 100%),
      radial-gradient(1.5px 1.5px at 55% 95%, rgba(251, 191, 36, 0.55) 50%, transparent 100%),
      radial-gradient(1px 1px at 70% 5%, rgba(255, 255, 255, 0.7) 50%, transparent 100%),
      radial-gradient(2px 2px at 10% 90%, rgba(255, 255, 255, 0.8) 50%, transparent 100%);
    animation: twinkle 4s ease-in-out 1s infinite alternate-reverse;
  }

  @keyframes twinkle {
    0% { opacity: 0.5; }
    50% { opacity: 0.85; }
    100% { opacity: 1; }
  }

  /* Hero 文字入场动画 */
  .hero-fade-in {
    animation: fadeInUp 0.8s ease-out forwards;
    opacity: 0;
    transform: translateY(20px);
  }

  .hero-delay-1 { animation-delay: 0.2s; }
  .hero-delay-2 { animation-delay: 0.4s; }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .typewriter-copy {
    display: inline;
    min-height: 1.75rem;
    font-family: 'JetBrains Mono', 'Noto Sans SC', monospace;
    letter-spacing: 0.02em;
  }

  .typewriter-caret {
    display: inline-block;
    width: 0.7ch;
    height: 1.15em;
    margin-left: 0.15rem;
    vertical-align: text-bottom;
    border-radius: 9999px;
    background: linear-gradient(180deg, rgba(125, 211, 252, 0.95), rgba(251, 191, 36, 0.85));
    box-shadow: 0 0 18px rgba(125, 211, 252, 0.35);
    animation: blinkCaret 1s steps(1) infinite;
  }

  @keyframes blinkCaret {
    0%, 48% { opacity: 1; }
    50%, 100% { opacity: 0.15; }
  }

  /* 头像发光 + 浮动动画 */
  .avatar-wrapper {
    animation: float 4s ease-in-out infinite;
  }

  .avatar-glow {
    position: absolute;
    inset: -6px;
    border-radius: 9999px;
    background: conic-gradient(
      from 0deg,
      rgba(251, 191, 36, 0.4),
      rgba(56, 189, 248, 0.3),
      rgba(168, 85, 247, 0.3),
      rgba(251, 191, 36, 0.4)
    );
    animation: glow-spin 6s linear infinite;
    filter: blur(8px);
    opacity: 0.7;
  }

  .avatar-img {
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .avatar-img:hover {
    transform: scale(1.05);
    box-shadow: 0 0 30px rgba(251, 191, 36, 0.4), 0 0 60px rgba(56, 189, 248, 0.2);
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-12px); }
  }

  @keyframes glow-spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  // ========== Canvas 流星动画 - 增强版 ==========
  const canvas = document.getElementById('meteor-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function resizeCanvas() {
    const hero = document.getElementById('hero')!;
    canvas.width = hero.offsetWidth;
    canvas.height = hero.offsetHeight;
  }
  resizeCanvas();
  window.addEventListener('resize', resizeCanvas);

  interface Meteor {
    x: number; y: number;
    len: number; speed: number;
    opacity: number; angle: number;
    dx: number; dy: number;
    width: number;
    hue: number; // 色调变化
  }

  const meteors: Meteor[] = [];
  let frameCount = 0;

  const typedTarget = document.getElementById('hero-typed');
  const caret = document.querySelector('.typewriter-caret');

  function runTypewriter() {
    if (!typedTarget) {
      return;
    }

    const fullText = typedTarget.getAttribute('data-text') ?? '';
    typedTarget.textContent = '';

    if (!fullText) {
      if (caret instanceof HTMLElement) {
        caret.style.display = 'none';
      }
      return;
    }

    let index = 0;
    const typeNext = () => {
      index += 1;
      typedTarget.textContent = fullText.slice(0, index);

      if (index < fullText.length) {
        window.setTimeout(typeNext, index < 8 ? 110 : 58);
        return;
      }

      window.setTimeout(() => {
        if (caret instanceof HTMLElement) {
          caret.style.opacity = '0.6';
        }
      }, 600);
    };

    window.setTimeout(typeNext, 500);
  }

  runTypewriter();

  function createMeteor(): Meteor {
    const angle = (Math.random() * 30 + 20) * (Math.PI / 180);
    const speed = Math.random() * 8 + 5; // 更快
    const isGolden = Math.random() > 0.3; // 70% 琥珀金, 30% 冰蓝
    return {
      x: Math.random() * canvas.width * 1.4,
      y: -30,
      len: Math.random() * 100 + 60, // 更长尾迹
      speed,
      opacity: Math.random() * 0.5 + 0.5, // 更亮
      angle,
      dx: Math.cos(angle) * speed,
      dy: Math.sin(angle) * speed,
      width: Math.random() * 1.5 + 1.5, // 更粗
      hue: isGolden ? 45 : 200, // 琥珀金 or 冰蓝
    };
  }

  function drawMeteor(m: Meteor) {
    const tailX = m.x - Math.cos(m.angle) * m.len;
    const tailY = m.y - Math.sin(m.angle) * m.len;
    const grad = ctx.createLinearGradient(m.x, m.y, tailX, tailY);

    if (m.hue === 45) {
      // 琥珀金流星
      grad.addColorStop(0, `rgba(251, 191, 36, ${m.opacity})`);
      grad.addColorStop(0.15, `rgba(255, 220, 100, ${m.opacity * 0.8})`);
      grad.addColorStop(0.4, `rgba(255, 255, 255, ${m.opacity * 0.5})`);
      grad.addColorStop(1, `rgba(255, 255, 255, 0)`);
    } else {
      // 冰蓝流星
      grad.addColorStop(0, `rgba(100, 200, 255, ${m.opacity})`);
      grad.addColorStop(0.15, `rgba(150, 220, 255, ${m.opacity * 0.8})`);
      grad.addColorStop(0.4, `rgba(255, 255, 255, ${m.opacity * 0.5})`);
      grad.addColorStop(1, `rgba(255, 255, 255, 0)`);
    }

    ctx.beginPath();
    ctx.moveTo(m.x, m.y);
    ctx.lineTo(tailX, tailY);
    ctx.strokeStyle = grad;
    ctx.lineWidth = m.width;
    ctx.lineCap = 'round';
    ctx.stroke();

    // 头部发光
    const glowColor = m.hue === 45
      ? `rgba(251, 191, 36, ${m.opacity})`
      : `rgba(100, 200, 255, ${m.opacity})`;
    ctx.beginPath();
    ctx.arc(m.x, m.y, 3, 0, Math.PI * 2);
    ctx.fillStyle = glowColor;
    ctx.fill();

    // 外层辉光
    ctx.beginPath();
    ctx.arc(m.x, m.y, 6, 0, Math.PI * 2);
    const glowGrad = ctx.createRadialGradient(m.x, m.y, 0, m.x, m.y, 6);
    const glowBase = m.hue === 45 ? '251, 191, 36' : '100, 200, 255';
    glowGrad.addColorStop(0, `rgba(${glowBase}, ${m.opacity * 0.6})`);
    glowGrad.addColorStop(1, `rgba(${glowBase}, 0)`);
    ctx.fillStyle = glowGrad;
    ctx.fill();
  }

  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    frameCount++;

    // 每 40~60 帧生成一颗流星，保证始终有多颗在飞
    const spawnChance = 0.06; // 6% 每帧，约每秒 1 颗
    if (Math.random() < spawnChance && meteors.length < 8) {
      meteors.push(createMeteor());
    }

    // 周期性爆发：每 3 秒额外产生 2~3 颗
    if (frameCount % 180 === 0) {
      const burst = Math.floor(Math.random() * 2) + 2;
      for (let i = 0; i < burst && meteors.length < 10; i++) {
        meteors.push(createMeteor());
      }
    }

    for (let i = meteors.length - 1; i >= 0; i--) {
      const m = meteors[i];
      m.x += m.dx;
      m.y += m.dy;
      m.opacity -= 0.002; // 更慢消失
      drawMeteor(m);
      if (m.y > canvas.height + 80 || m.opacity <= 0) {
        meteors.splice(i, 1);
      }
    }
    requestAnimationFrame(animate);
  }
  animate();

  // ========== 鼠标视差效果 ==========
  const heroBg = document.getElementById('hero-bg');
  const heroSection = document.getElementById('hero');
  if (heroBg && heroSection) {
    heroSection.addEventListener('mousemove', (e) => {
      const rect = heroSection.getBoundingClientRect();
      const x = (e.clientX - rect.left) / rect.width - 0.5;
      const y = (e.clientY - rect.top) / rect.height - 0.5;
      heroBg.style.transform = `translate(${x * -15}px, ${y * -15}px)`;
    });
    heroSection.addEventListener('mouseleave', () => {
      heroBg.style.transform = 'translate(0, 0)';
      heroBg.style.transition = 'transform 0.5s ease-out';
      setTimeout(() => { heroBg.style.transition = ''; }, 500);
    });
  }
</script>
