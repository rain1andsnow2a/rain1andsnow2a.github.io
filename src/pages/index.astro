  .typewriter-caret {
    display: inline-block;
    width: 0.7ch;
    height: 1.1em;
    margin-left: 0.18rem;
    vertical-align: text-bottom;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(251, 191, 36, 0.82));
    box-shadow: 0 0 18px rgba(255, 255, 255, 0.25);
    animation: blinkCaret 1s steps(1) infinite;
  }

  @keyframes blinkCaret {
    0%, 48% { opacity: 1; }
    50%, 100% { opacity: 0.18; }
