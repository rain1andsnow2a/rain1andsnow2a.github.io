---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const featuredPosts = posts.slice(0, 6);
const postCount = posts.length;
const categoryMap = posts.reduce((acc, post) => {
  const key = post.data.category || '未分类';
  if (!acc.has(key)) acc.set(key, []);
  acc.get(key)?.push(post);
  return acc;
}, new Map<string, typeof posts>());

const categories = Array.from(categoryMap.entries())
  .map(([name, items]) => ({ name, count: items.length }))
  .sort((a, b) => b.count - a.count);

const tagMap = posts.reduce((acc, post) => {
  for (const tag of post.data.tags) {
    acc.set(tag, (acc.get(tag) || 0) + 1);
  }
  return acc;
}, new Map<string, number>());

const tags = Array.from(tagMap.entries())
  .map(([name, count]) => ({ name, count }))
  .sort((a, b) => b.count - a.count);

const tagCount = tags.length;
const categoryCount = categories.length;
const profileBadges = [
  { href: 'https://github.com/rain1andsnow2a', label: 'GitHub', icon: 'lucide:github' },
  { href: 'mailto:rain1andsnow2a@outlook.com', label: 'Email', icon: 'lucide:user' },
  { href: '/categories', label: '分类', icon: 'lucide:book-open' },
];

const cardImages = ['/hero-bg-new_1.png', '/hero-bg-v2_1.png', '/hero-bg_1.png'];
---

<BaseLayout title="首页" description="晨熠的个人博客 - 深空中的丁火">
  <Header />

  <main class="flex-1">
    <section class="mx-auto max-w-[1500px] px-6 pb-8 pt-6">
      <div class="hero-shell relative overflow-hidden rounded-[2rem] border border-white/60 shadow-[0_28px_70px_rgba(15,23,42,0.16)]">
        <img
          src="/hero-bg-new_1.png"
          alt="深空中的丁火"
          class="absolute inset-0 h-full w-full object-cover"
        />
        <div class="absolute inset-0 bg-[linear-gradient(90deg,rgba(15,23,42,0.76)_0%,rgba(15,23,42,0.46)_38%,rgba(30,41,59,0.22)_100%)]"></div>
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(255,197,86,0.25),transparent_18%),radial-gradient(circle_at_70%_20%,rgba(255,255,255,0.16),transparent_16%)]"></div>

        <div class="relative z-10 grid min-h-[520px] gap-8 px-8 py-10 lg:grid-cols-[minmax(0,1.2fr)_320px] lg:px-12 lg:py-12">
          <div class="flex flex-col justify-center">
            <div class="mb-5 inline-flex items-center gap-3 text-amber-300">
              <span class="rounded-full border border-amber-300/40 bg-white/10 px-3 py-1 text-xs font-medium tracking-[0.28em] text-amber-200">
                COSMIC NOTEBOOK
              </span>
            </div>

            <div class="hero-reveal hero-delay-0 flex items-center gap-4">
              <span class="flex h-14 w-14 items-center justify-center rounded-2xl border border-amber-300/35 bg-amber-300/12 text-amber-300 shadow-[0_0_30px_rgba(251,191,36,0.18)]">
                <Icon name="lucide:sparkles" class="h-7 w-7" />
              </span>
              <div>
                <h1 class="hero-title text-white">晨熠</h1>
                <div class="mt-2 h-1.5 w-44 rounded-full bg-[linear-gradient(90deg,#fb923c_0%,#fdba74_50%,transparent_100%)]"></div>
              </div>
            </div>

            <p class="hero-reveal hero-delay-1 mt-8 text-4xl font-semibold tracking-tight text-white/95">
              深空中的丁火，寒夜里的极光
            </p>

            <p class="hero-reveal hero-delay-2 mt-6 max-w-2xl text-xl leading-relaxed text-slate-100/92">
              <span
                id="hero-typed"
                class="typewriter-copy"
                data-text="记录技术探索、思考与成长。在广袤的信息宇宙中，这里是一颗安静燃烧的星。"
              ></span>
              <span class="typewriter-caret" aria-hidden="true"></span>
            </p>

            <div class="hero-reveal hero-delay-3 mt-10 flex flex-wrap items-center gap-4">
              <a
                href="/blog"
                class="inline-flex items-center gap-2 rounded-2xl bg-[linear-gradient(135deg,#fb923c,#f97316)] px-7 py-4 text-base font-semibold text-white shadow-[0_18px_38px_rgba(249,115,22,0.35)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_22px_46px_rgba(249,115,22,0.42)]"
              >
                <Icon name="lucide:arrow-right" class="h-4 w-4" />
                探索文章
              </a>
              <a
                href="#about"
                class="inline-flex items-center gap-2 rounded-2xl border border-white/55 bg-white/8 px-7 py-4 text-base font-semibold text-white backdrop-blur-sm transition-all duration-300 hover:bg-white/14"
              >
                <Icon name="lucide:user" class="h-4 w-4" />
                关于我
              </a>
            </div>
          </div>

          <aside class="hero-reveal hero-delay-2 flex items-center lg:justify-end">
            <div class="w-full rounded-[2rem] border border-white/20 bg-[linear-gradient(180deg,rgba(36,50,104,0.62),rgba(18,29,69,0.56))] p-7 text-white shadow-[0_30px_60px_rgba(15,23,42,0.24)] backdrop-blur-xl">
              <div class="mx-auto h-28 w-28 overflow-hidden rounded-full border-4 border-white/40 shadow-[0_18px_42px_rgba(15,23,42,0.25)]">
                <img
                  src="/头像.png"
                  alt="晨熠的头像"
                  class="h-full w-full object-cover"
                />
              </div>
              <h2 class="mt-5 text-center text-4xl font-semibold text-white">晨熠</h2>
              <p class="mt-2 text-center text-lg text-slate-200/92">Explorer & Dreamer</p>

              <div class="mt-8 grid grid-cols-3 gap-3 text-center">
                <div>
                  <div class="text-3xl font-bold text-white">{postCount}</div>
                  <div class="mt-1 text-sm text-slate-200/80">文章</div>
                </div>
                <div>
                  <div class="text-3xl font-bold text-white">{categoryCount}</div>
                  <div class="mt-1 text-sm text-slate-200/80">分类</div>
                </div>
                <div>
                  <div class="text-3xl font-bold text-white">{tagCount}</div>
                  <div class="mt-1 text-sm text-slate-200/80">标签</div>
                </div>
              </div>

              <div class="mt-7 flex items-center justify-center gap-3">
                {profileBadges.map((item) => (
                  <a
                    href={item.href}
                    target={item.href.startsWith('http') || item.href.startsWith('mailto:') ? '_blank' : undefined}
                    rel={item.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                    aria-label={item.label}
                    class="flex h-12 w-12 items-center justify-center rounded-2xl border border-white/18 bg-white/12 text-white/90 transition-all duration-300 hover:-translate-y-0.5 hover:bg-white/20"
                  >
                    <Icon name={item.icon} class="h-5 w-5" />
                  </a>
                ))}
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-[1500px] px-6 pb-16">
      <div class="grid gap-8 xl:grid-cols-[minmax(0,1fr)_320px]">
        <div>
          <div class="mb-6 flex items-center justify-between">
            <h2 class="flex items-center gap-2 text-4xl font-semibold text-slate-900">
              <Icon name="lucide:book-open" class="h-7 w-7 text-orange-500" />
              最近文章
            </h2>
            <a
              href="/blog"
              class="group inline-flex items-center gap-2 text-lg font-medium text-orange-500 transition-colors hover:text-orange-600"
            >
              查看全部
              <Icon name="lucide:arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
            </a>
          </div>

          <div class="grid gap-6 md:grid-cols-2 2xl:grid-cols-3">
            {featuredPosts.map((post, index) => {
              const formattedDate = post.data.pubDate.toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: 'numeric',
                day: 'numeric',
              });
              const readingMinutes = Math.max(4, Math.ceil((post.body?.length || 800) / 420));
              const cover = cardImages[index % cardImages.length];

              return (
                <a
                  href={`/blog/${post.id}`}
                  class="group overflow-hidden rounded-[1.6rem] border border-slate-200 bg-white shadow-[0_18px_50px_rgba(15,23,42,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_24px_60px_rgba(15,23,42,0.12)]"
                >
                  <div class="relative h-52 overflow-hidden">
                    <img
                      src={cover}
                      alt={post.data.title}
                      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    />
                    <div class="absolute inset-0 bg-[linear-gradient(180deg,transparent_0%,rgba(15,23,42,0.55)_100%)]"></div>
                  </div>

                  <div class="px-6 pb-6 pt-5">
                    <div class="mb-3 flex flex-wrap gap-2">
                      <span class="rounded-full bg-indigo-50 px-3 py-1 text-xs font-semibold text-indigo-600">
                        {post.data.category}
                      </span>
                      {post.data.tags[0] && (
                        <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-600">
                          {post.data.tags[0]}
                        </span>
                      )}
                    </div>

                    <h3 class="text-3xl font-semibold leading-snug text-slate-900">
                      {post.data.title}
                    </h3>
                    <p class="mt-3 line-clamp-2 text-base leading-7 text-slate-500">
                      {post.data.description || '继续向更深处走，记录路上的思考、技术与光。'}
                    </p>

                    <div class="mt-5 flex flex-wrap items-center gap-4 text-sm text-slate-400">
                      <span class="inline-flex items-center gap-1.5">
                        <Icon name="lucide:file-text" class="h-4 w-4" />
                        {formattedDate}
                      </span>
                      <span class="inline-flex items-center gap-1.5">
                        <Icon name="lucide:book-open" class="h-4 w-4" />
                        {readingMinutes} 分钟阅读
                      </span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        </div>

        <aside class="space-y-6">
          <section class="rounded-[1.7rem] border border-slate-200 bg-white p-6 shadow-[0_18px_50px_rgba(15,23,42,0.08)]">
            <h3 class="text-3xl font-semibold text-slate-900">分类</h3>
            <div class="mt-5 space-y-3">
              {categories.slice(0, 6).map((category, index) => {
                const accentClasses = [
                  'text-indigo-600 bg-indigo-50',
                  'text-emerald-600 bg-emerald-50',
                  'text-sky-600 bg-sky-50',
                  'text-orange-600 bg-orange-50',
                  'text-rose-600 bg-rose-50',
                  'text-violet-600 bg-violet-50',
                ];
                const accent = accentClasses[index % accentClasses.length];

                return (
                  <a
                    href={`/categories/${encodeURIComponent(category.name)}`}
                    class="flex items-center justify-between rounded-2xl px-3 py-3 transition-colors hover:bg-slate-50"
                  >
                    <span class="flex items-center gap-3">
                      <span class={`flex h-9 w-9 items-center justify-center rounded-xl ${accent}`}>
                        <Icon name="lucide:book-open" class="h-4 w-4" />
                      </span>
                      <span class="text-lg font-medium text-slate-700">{category.name}</span>
                    </span>
                    <span class="text-lg font-semibold text-slate-400">{category.count}</span>
                  </a>
                );
              })}
            </div>
          </section>

          <section id="tags" class="rounded-[1.7rem] border border-slate-200 bg-white p-6 shadow-[0_18px_50px_rgba(15,23,42,0.08)]">
            <h3 class="text-3xl font-semibold text-slate-900">标签云</h3>
            <div class="mt-5 flex flex-wrap gap-3">
              {tags.map((tag, index) => {
                const palette = [
                  'bg-sky-50 text-sky-600',
                  'bg-emerald-50 text-emerald-600',
                  'bg-violet-50 text-violet-600',
                  'bg-orange-50 text-orange-600',
                  'bg-rose-50 text-rose-600',
                  'bg-indigo-50 text-indigo-600',
                ];
                return (
                  <span class={`rounded-full px-4 py-2 text-sm font-medium ${palette[index % palette.length]}`}>
                    {tag.name}
                  </span>
                );
              })}
            </div>
          </section>
        </aside>
      </div>

      <section id="about" class="mt-12 rounded-[1.8rem] border border-slate-200 bg-white px-8 py-7 shadow-[0_18px_50px_rgba(15,23,42,0.06)]">
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <div class="max-w-3xl">
            <h2 class="text-3xl font-semibold text-slate-900">关于</h2>
            <p class="mt-3 text-lg leading-8 text-slate-600">
              我是晨熠，一个热爱技术的探索者。这个博客是我的数字花园，记录学习路上的点滴收获，也记录那些在宇宙般的信息海洋中被我真正抓住的火花。
            </p>
          </div>
          <a
            href="https://github.com/rain1andsnow2a"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-2xl border border-slate-200 px-6 py-3 text-base font-medium text-slate-700 transition-all duration-300 hover:-translate-y-0.5 hover:border-orange-300 hover:text-orange-500"
          >
            <Icon name="lucide:github" class="h-5 w-5" />
            访问 GitHub
          </a>
        </div>
      </section>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .hero-shell::after {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(circle at 16% 18%, rgba(255, 255, 255, 0.26), transparent 20%),
      radial-gradient(circle at 86% 24%, rgba(147, 197, 253, 0.24), transparent 16%),
      radial-gradient(circle at 80% 78%, rgba(251, 191, 36, 0.12), transparent 18%);
    mix-blend-mode: screen;
  }

  .hero-title {
    font-size: clamp(4.3rem, 8vw, 6.8rem);
    line-height: 0.92;
    letter-spacing: -0.06em;
    font-weight: 800;
    text-shadow: 0 10px 36px rgba(15, 23, 42, 0.24);
  }

  .hero-reveal {
    animation: heroRise 0.82s ease-out forwards;
    opacity: 0;
    transform: translateY(22px);
  }

  .hero-delay-0 { animation-delay: 0.05s; }
  .hero-delay-1 { animation-delay: 0.18s; }
  .hero-delay-2 { animation-delay: 0.3s; }
  .hero-delay-3 { animation-delay: 0.42s; }

  @keyframes heroRise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .typewriter-copy {
    display: inline;
    min-height: 1.75rem;
    font-family: 'JetBrains Mono', 'Noto Sans SC', monospace;
    letter-spacing: 0.02em;
  }

  .typewriter-caret {
    display: inline-block;
    width: 0.7ch;
    height: 1.1em;
    margin-left: 0.18rem;
    vertical-align: text-bottom;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(251, 191, 36, 0.82));
    box-shadow: 0 0 18px rgba(255, 255, 255, 0.25);
    animation: blinkCaret 1s steps(1) infinite;
  }

  @keyframes blinkCaret {
    0%, 48% { opacity: 1; }
    50%, 100% { opacity: 0.18; }
  }

  @media (max-width: 1024px) {
    .hero-shell {
      border-radius: 1.5rem;
    }
  }
</style>

<script>
  const typedTarget = document.getElementById('hero-typed');
  const caret = document.querySelector('.typewriter-caret');

  function runTypewriter() {
    if (!typedTarget) return;

    const fullText = typedTarget.getAttribute('data-text') ?? '';
    typedTarget.textContent = '';

    if (!fullText) {
      if (caret instanceof HTMLElement) caret.style.display = 'none';
      return;
    }

    let index = 0;
    const typeNext = () => {
      index += 1;
      typedTarget.textContent = fullText.slice(0, index);

      if (index < fullText.length) {
        window.setTimeout(typeNext, index < 8 ? 95 : 50);
      }
    };

    window.setTimeout(typeNext, 500);
  }

  runTypewriter();
</script>
