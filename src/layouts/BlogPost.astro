---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  category?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, category = '未分类', tags = [] } = Astro.props;

const formattedDate = pubDate
  ? pubDate.toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const formattedUpdated = updatedDate
  ? updatedDate.toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const wordCount = '静读一篇';
const readTime = '约 5 分钟';
---

<BaseLayout title={title} description={description} pubDate={pubDate}>
  <Header />

  <main class="flex-1">
    <section class="mx-auto max-w-[1500px] px-6 pb-8 pt-6">
      <div class="relative overflow-hidden rounded-[2rem] border border-white/70 bg-[linear-gradient(135deg,#ffffff_0%,#fff8ef_46%,#f6fbff_100%)] px-8 py-10 shadow-[0_28px_70px_rgba(15,23,42,0.10)]">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_12%_20%,rgba(251,146,60,0.12),transparent_22%),radial-gradient(circle_at_82%_18%,rgba(56,189,248,0.12),transparent_22%)]"></div>
        <div class="relative grid gap-8 lg:grid-cols-[minmax(0,1fr)_280px]">
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <a
                href={`/categories/${encodeURIComponent(category)}`}
                class="inline-flex items-center gap-2 rounded-full bg-emerald-50 px-4 py-1.5 text-sm font-semibold text-emerald-600"
              >
                <Icon name="lucide:book-open" class="h-4 w-4" />
                {category}
              </a>
              {tags.map((tag) => (
                <span class="rounded-full bg-sky-50 px-4 py-1.5 text-sm font-semibold text-sky-600">
                  {tag}
                </span>
              ))}
            </div>

            <h1 class="mt-6 max-w-4xl text-5xl font-bold leading-tight tracking-tight text-slate-900 md:text-6xl">
              {title}
            </h1>

            {description && (
              <p class="mt-5 max-w-3xl text-xl leading-9 text-slate-600">
                {description}
              </p>
            )}

            <div class="mt-8 flex flex-wrap items-center gap-3 text-sm text-slate-500">
              {formattedDate && (
                <span class="rounded-full border border-slate-200 bg-white/80 px-4 py-2">
                  发布于 {formattedDate}
                </span>
              )}
              {formattedUpdated && (
                <span class="rounded-full border border-slate-200 bg-white/80 px-4 py-2">
                  更新于 {formattedUpdated}
                </span>
              )}
              <span class="rounded-full border border-slate-200 bg-white/80 px-4 py-2">
                {wordCount}
              </span>
              <span class="rounded-full border border-slate-200 bg-white/80 px-4 py-2">
                {readTime}
              </span>
            </div>
          </div>

          <aside class="flex items-start lg:justify-end">
            <div class="w-full rounded-[1.8rem] border border-slate-200 bg-white/90 p-6 shadow-[0_18px_50px_rgba(15,23,42,0.08)]">
              <div class="mx-auto h-24 w-24 overflow-hidden rounded-full border-4 border-orange-100 shadow-[0_12px_30px_rgba(15,23,42,0.10)]">
                <img src="/头像.png" alt="晨熠的头像" class="h-full w-full object-cover" />
              </div>
              <h2 class="mt-5 text-center text-3xl font-semibold text-slate-900">晨熠</h2>
              <p class="mt-2 text-center text-base text-slate-500">Explorer & Dreamer</p>

              <div class="mt-6 space-y-3">
                <a
                  href="https://github.com/rain1andsnow2a"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center justify-center gap-2 rounded-2xl bg-slate-900 px-4 py-3 text-base font-medium text-white transition-colors hover:bg-slate-800"
                >
                  <Icon name="lucide:github" class="h-4 w-4" />
                  GitHub
                </a>
                <a
                  href="/blog"
                  class="flex items-center justify-center gap-2 rounded-2xl border border-slate-200 px-4 py-3 text-base font-medium text-slate-700 transition-colors hover:border-orange-200 hover:text-orange-500"
                >
                  <Icon name="lucide:arrow-right" class="h-4 w-4" />
                  返回文章列表
                </a>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="mx-auto max-w-[980px] px-6 pb-16">
      <article class="overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-[0_24px_60px_rgba(15,23,42,0.08)]">
        <div
          class="prose prose-lg max-w-none px-8 py-10 text-slate-700 prose-headings:text-slate-900 prose-headings:scroll-mt-24 prose-p:leading-8 prose-a:text-sky-700 prose-a:no-underline hover:prose-a:text-sky-500 hover:prose-a:underline prose-strong:text-slate-900 prose-code:text-orange-600 prose-code:before:content-[''] prose-code:after:content-[''] prose-pre:border prose-pre:border-slate-200 prose-pre:bg-slate-950 prose-blockquote:border-orange-300 prose-blockquote:bg-orange-50/40 prose-blockquote:px-5 prose-blockquote:py-2 prose-blockquote:text-slate-600 prose-hr:border-slate-200 prose-img:rounded-2xl"
        >
          <slot />
        </div>
      </article>
    </section>
  </main>

  <Footer />
</BaseLayout>
