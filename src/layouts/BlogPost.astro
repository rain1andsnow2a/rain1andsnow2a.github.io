---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
}

const { title, description, pubDate } = Astro.props;

const formattedDate = pubDate
  ? pubDate.toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;
---

<BaseLayout title={title} description={description} pubDate={pubDate}>
  <Header />
  <main class="max-w-3xl mx-auto px-6 py-10 flex-1 w-full">
    <article>
      {formattedDate && (
        <time datetime={pubDate!.toISOString()} class="text-sm text-slate-500 mb-4 block">
          {formattedDate}
        </time>
      )}
      <div class="prose prose-invert prose-slate max-w-none
        prose-headings:text-slate-100
        prose-a:text-amber-400 prose-a:no-underline hover:prose-a:text-amber-300 hover:prose-a:underline
        prose-code:text-amber-400 prose-code:before:content-[''] prose-code:after:content-['']
        prose-pre:bg-slate-800/50 prose-pre:border prose-pre:border-slate-700
        prose-blockquote:border-amber-400/50 prose-blockquote:text-slate-400
        prose-hr:border-slate-700
        prose-strong:text-slate-100
      ">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>
