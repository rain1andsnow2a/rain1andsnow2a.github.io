---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { Icon } from 'astro-icon/components';

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, tags = [] } = Astro.props;

const formattedDate = pubDate
  ? pubDate.toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const formattedUpdated = updatedDate
  ? updatedDate.toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

// Simulated stats (can be replaced with real analytics later)
const wordCount = '约 1.5k 字';
const readTime = '约 5 分钟';
---

<BaseLayout title={title} description={description} pubDate={pubDate}>
  <Header />

  <!-- Hero Banner -->
  <div class="relative overflow-hidden border-b border-stone-200 bg-[linear-gradient(180deg,rgba(255,255,255,0.92),rgba(248,244,236,0.96))]">
    <!-- Decorative elements -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(14,165,233,0.10),transparent_60%)]"></div>
    <div class="absolute top-0 right-0 h-64 w-64 translate-x-1/4 -translate-y-1/2 rounded-full bg-amber-300/10 blur-3xl"></div>

    <div class="relative max-w-3xl mx-auto px-6 pt-10 pb-8">
      <!-- Tags -->
      {tags.length > 0 && (
        <div class="flex flex-wrap items-center gap-2 mb-4">
          {tags.map((tag) => (
            <span class="inline-flex items-center gap-1 rounded-full border border-sky-200 bg-sky-50 px-2.5 py-1 text-xs font-medium text-sky-700 backdrop-blur-sm">
              <Icon name="lucide:hash" class="w-3 h-3" />
              {tag}
            </span>
          ))}
        </div>
      )}

      <!-- Title -->
      <h1 class="mb-3 text-3xl font-bold leading-tight text-slate-900 md:text-4xl">
        {title}
      </h1>

      <!-- Description -->
      {description && (
        <p class="mb-5 max-w-2xl text-base leading-relaxed text-slate-600">
          {description}
        </p>
      )}

      <!-- Meta row -->
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-slate-500">
        {formattedDate && (
          <span class="flex items-center gap-1.5">
            <Icon name="lucide:calendar" class="w-3.5 h-3.5" />
            发表于 {formattedDate}
          </span>
        )}
        {formattedUpdated && (
          <span class="flex items-center gap-1.5">
            <Icon name="lucide:refresh-cw" class="w-3.5 h-3.5" />
            更新于 {formattedUpdated}
          </span>
        )}
        <span class="flex items-center gap-1.5">
          <Icon name="lucide:file-text" class="w-3.5 h-3.5" />
          {wordCount}
        </span>
        <span class="flex items-center gap-1.5">
          <Icon name="lucide:clock" class="w-3.5 h-3.5" />
          {readTime}
        </span>
      </div>

      <!-- Stats row: views & likes -->
      <div class="mt-4 flex items-center gap-4 border-t border-stone-200 pt-4">
        <span class="flex cursor-default items-center gap-1.5 text-sm text-slate-500 transition-colors hover:text-sky-600">
          <Icon name="lucide:eye" class="w-4 h-4" />
          <span id="view-count">--</span> 阅读
        </span>
        <button id="like-btn" class="group flex items-center gap-1.5 text-sm text-slate-500 transition-colors hover:text-rose-500">
          <Icon name="lucide:heart" class="w-4 h-4 group-hover:scale-110 transition-transform" />
          <span id="like-count">--</span> 点赞
        </button>
        <button class="ml-auto flex items-center gap-1.5 text-sm text-slate-500 transition-colors hover:text-amber-600" onclick="navigator.clipboard.writeText(window.location.href).then(()=>this.querySelector('span').textContent='已复制!')">
          <Icon name="lucide:share-2" class="w-4 h-4" />
          <span>分享</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Article Content -->
  <main class="flex-1 w-full max-w-3xl mx-auto px-6 py-10">
    <article>
      <div class="prose max-w-none rounded-[2rem] border border-stone-200 bg-white/88 px-8 py-10 shadow-[0_22px_52px_rgba(148,163,184,0.10)]
        prose-slate
        prose-headings:text-slate-900
        prose-a:text-sky-700 prose-a:no-underline hover:prose-a:text-sky-500 hover:prose-a:underline
        prose-code:text-amber-700 prose-code:before:content-[''] prose-code:after:content-['']
        prose-pre:border prose-pre:border-stone-200 prose-pre:bg-stone-950
        prose-blockquote:border-amber-400/60 prose-blockquote:text-slate-600
        prose-hr:border-stone-200
        prose-strong:text-slate-900
      ">
        <slot />
      </div>
    </article>
  </main>
  <Footer />
</BaseLayout>

<script>
  // Simple localStorage-based view counter & likes (per article)
  const slug = window.location.pathname;
  const viewKey = `blog_views_${slug}`;
  const likeKey = `blog_likes_${slug}`;
  const likedKey = `blog_liked_${slug}`;

  // Views
  let views = parseInt(localStorage.getItem(viewKey) || '0') + 1;
  localStorage.setItem(viewKey, String(views));
  const viewEl = document.getElementById('view-count');
  if (viewEl) viewEl.textContent = String(views);

  // Likes
  let likes = parseInt(localStorage.getItem(likeKey) || '0');
  const likeEl = document.getElementById('like-count');
  if (likeEl) likeEl.textContent = String(likes);

  const likeBtn = document.getElementById('like-btn');
  if (likeBtn) {
    // Show liked state
    if (localStorage.getItem(likedKey)) {
      likeBtn.classList.add('text-rose-400');
      likeBtn.classList.remove('text-slate-500');
    }
    likeBtn.addEventListener('click', () => {
      if (localStorage.getItem(likedKey)) return;
      likes++;
      localStorage.setItem(likeKey, String(likes));
      localStorage.setItem(likedKey, '1');
      if (likeEl) likeEl.textContent = String(likes);
      likeBtn.classList.add('text-rose-400');
      likeBtn.classList.remove('text-slate-500');
    });
  }
</script>
