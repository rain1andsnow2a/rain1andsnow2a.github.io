---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LocalIcon from '../components/LocalIcon.astro';
import katex from 'katex';

function renderTocItem(text: string): string {
  const escapeHtml = (s: string) =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  const parts: string[] = [];
  let i = 0;
  while (i < text.length) {
    const dollar = text.indexOf('$', i);
    if (dollar === -1) {
      parts.push(escapeHtml(text.slice(i)));
      break;
    }
    if (dollar > i) parts.push(escapeHtml(text.slice(i, dollar)));
    const end = text.indexOf('$', dollar + 1);
    if (end === -1) {
      parts.push(escapeHtml(text.slice(dollar)));
      break;
    }
    const expr = text.slice(dollar + 1, end);
    try {
      parts.push(katex.renderToString(expr, { throwOnError: false, output: 'html' }));
    } catch {
      parts.push(escapeHtml(text.slice(dollar, end + 1)));
    }
    i = end + 1;
  }
  return parts.join('');
}

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  category?: string;
  tags?: string[];
  cover?: string;
  body?: string;
  headings?: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const { title, description, cover, pubDate, updatedDate, category = '未分类', tags = [], headings = [], body = '' } = Astro.props;

const formattedDate = pubDate
  ? pubDate.toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const formattedUpdated = updatedDate
  ? updatedDate.toLocaleDateString('zh-CN', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const plainBody = body
  .replace(/```[\s\S]*?```/g, ' ')
  .replace(/`[^`]*`/g, ' ')
  .replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
  .replace(/\[[^\]]*\]\([^)]+\)/g, ' ')
  .replace(/[#>*_\-\[\]()`~|]/g, ' ');
const chineseCount = (plainBody.match(/[\u4e00-\u9fff]/g) || []).length;
const wordLikeCount = (plainBody.match(/[A-Za-z0-9]+(?:[-_][A-Za-z0-9]+)*/g) || []).length;
const totalWordCount = chineseCount + wordLikeCount;
const displayWordCount = totalWordCount.toLocaleString('zh-CN');
const readMinutes = Math.max(1, Math.ceil(totalWordCount / 420));
const wordCount = `${displayWordCount} 字`;
const readTime = `约 ${readMinutes} 分钟`;
const tocItems = headings.filter((heading) => heading.depth === 2 || heading.depth === 3);
---

<BaseLayout title={title} description={description} pubDate={pubDate}>
  <Header />

  <main class="flex-1">
    <section class="mx-auto max-w-[1500px] px-6 pb-8 pt-6">
      <div class="relative overflow-hidden rounded-2xl border border-orange-100 bg-[linear-gradient(105deg,#fffaf2_0%,#ffffff_46%,#eef8ff_100%)] px-8 py-8 shadow-[0_18px_45px_rgba(15,23,42,0.08)]">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_8%_58%,rgba(251,146,60,0.14),transparent_18%),radial-gradient(circle_at_92%_16%,rgba(56,189,248,0.14),transparent_20%)]"></div>
        <div class="absolute left-0 bottom-0 h-full w-72 opacity-45">
          <div class="h-full w-full bg-[radial-gradient(circle_at_18%_58%,rgba(251,191,36,0.22),transparent_16%),linear-gradient(135deg,rgba(251,146,60,0.16),transparent_54%)]"></div>
        </div>

        <div class="relative grid gap-8 lg:grid-cols-[minmax(0,1fr)_280px] lg:items-center">
          <div>
            <div class="flex flex-wrap items-center gap-2">
              <a
                href={`/categories/${encodeURIComponent(category)}`}
                class="inline-flex items-center gap-2 rounded-full bg-orange-50 px-4 py-1.5 text-sm font-semibold text-orange-500"
              >
                <LocalIcon name="book-open" class="h-4 w-4" />
                {category}
              </a>
              {tags.map((tag) => (
                <span class="rounded-full bg-sky-50 px-4 py-1.5 text-sm font-semibold text-sky-600">
                  {tag}
                </span>
              ))}
            </div>

            <h1 class="article-title-display mt-5 max-w-4xl text-5xl font-bold leading-tight tracking-tight text-slate-900">
              {title}
            </h1>

            {description && (
              <p class="article-description mt-5 max-w-3xl text-xl text-slate-600">
                {description}
              </p>
            )}

            <div class="mt-7 flex flex-wrap items-center gap-3 text-sm text-slate-500">
              {formattedDate && (
                <span class="rounded-full border border-slate-200 bg-white/90 px-4 py-2 shadow-[0_8px_20px_rgba(15,23,42,0.04)]">
                  发布于 {formattedDate}
                </span>
              )}
              {formattedUpdated && (
                <span class="rounded-full border border-slate-200 bg-white/90 px-4 py-2 shadow-[0_8px_20px_rgba(15,23,42,0.04)]">
                  更新于 {formattedUpdated}
                </span>
              )}
              <span class="rounded-full border border-slate-200 bg-white/90 px-4 py-2 shadow-[0_8px_20px_rgba(15,23,42,0.04)]">
                {wordCount}
              </span>
              <span class="rounded-full border border-slate-200 bg-white/90 px-4 py-2 shadow-[0_8px_20px_rgba(15,23,42,0.04)]">
                {readTime}
              </span>
            </div>
          </div>

          <aside class="flex items-start lg:justify-end">
            <div class="w-full rounded-2xl border border-slate-200 bg-white/92 p-5 shadow-[0_16px_40px_rgba(15,23,42,0.08)]">
              <div class="mx-auto h-24 w-24 overflow-hidden rounded-full border-4 border-orange-100 shadow-[0_12px_30px_rgba(15,23,42,0.10)]">
                <img src="/头像.png" alt="晨熠的头像" class="h-full w-full object-cover" />
              </div>
              <h2 class="mt-4 text-center text-2xl font-semibold text-slate-900">晨熠</h2>

              <div class="mt-5 space-y-3">
                <a
                  href="https://github.com/rain1andsnow2a"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex items-center justify-center gap-2 rounded-xl bg-slate-900 px-4 py-2.5 text-base font-medium text-white transition-colors hover:bg-slate-800"
                >
                  <LocalIcon name="github" class="h-4 w-4" />
                  GitHub
                </a>
                <a
                  href="/blog"
                  class="flex items-center justify-center gap-2 rounded-xl border border-slate-200 px-4 py-2.5 text-base font-medium text-slate-700 transition-colors hover:border-orange-200 hover:text-orange-500"
                >
                  <LocalIcon name="arrow-right" class="h-4 w-4" />
                  返回文章列表
                </a>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section class="mx-auto grid max-w-[1360px] gap-8 px-6 pb-16 lg:grid-cols-[280px_minmax(0,1fr)]">
      <aside class="hidden lg:block">
        <div class="sticky top-28 rounded-2xl border border-slate-200 bg-white p-6 shadow-[0_14px_36px_rgba(15,23,42,0.06)]">
          <h2 class="mb-5 flex items-center gap-2 text-xl font-semibold text-slate-900">
            <LocalIcon name="book-open" class="h-5 w-5 text-orange-500" />
            目录
          </h2>
          <div class="space-y-2 border-l border-slate-100">
            {tocItems.map((item, index) => (
              <a
                href={`#${item.slug}`}
                class:list={[
                'pl-4 text-lg leading-10 transition-colors',
                item.depth === 3 ? 'block pl-8 text-base' : 'block',
                index === 0 ? 'border-l-2 border-orange-400 text-orange-500 -ml-px font-medium' : 'text-slate-500 hover:text-orange-500',
              ]} set:html={renderTocItem(item.text)}>
              </a>
            ))}
          </div>
          <div class="mt-6 border-t border-slate-100 pt-4 text-base text-slate-400">
            共 {tocItems.length} 个章节
          </div>
        </div>
      </aside>

      <article class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-[0_20px_50px_rgba(15,23,42,0.07)]">
        {cover && (
          <div class="article-cover">
            <img src={cover} alt={title} class="h-full w-full object-cover" />
          </div>
        )}
        <div class="px-8 pt-7">
          <div class="mb-4 flex items-center justify-start">
            <span class="article-word-total inline-flex items-center gap-2 rounded-full border border-slate-200 bg-stone-50 px-4 py-2 text-sm font-medium text-slate-600">
              <LocalIcon name="file-text" class="h-4 w-4 text-orange-500" />
              字数总计 {wordCount}
            </span>
          </div>
          <div class="h-1.5 rounded-full bg-slate-100">
            <div id="reading-progress-bar" class="h-full w-0 rounded-full bg-orange-400 transition-[width] duration-150"></div>
          </div>
          <div class="mt-2 flex items-center justify-between text-sm text-slate-400">
            <span id="reading-progress-label">阅读进度 0%</span>
            <span id="reading-remaining-label">继续阅读</span>
          </div>
        </div>
        <div
          id="article-content"
          class="article-prose prose prose-lg max-w-none px-8 py-8 text-slate-700 prose-headings:text-slate-900 prose-headings:scroll-mt-24 prose-a:text-sky-700 prose-a:no-underline hover:prose-a:text-sky-500 hover:prose-a:underline prose-strong:text-slate-900 prose-code:before:content-[''] prose-code:after:content-[''] prose-blockquote:border-orange-300 prose-blockquote:bg-orange-50/40 prose-blockquote:px-5 prose-blockquote:py-2 prose-blockquote:text-slate-600 prose-hr:border-slate-200 prose-img:rounded-2xl"
        >
          <slot />
        </div>
      </article>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const articleContent = document.getElementById('article-content');
  const progressBar = document.getElementById('reading-progress-bar');
  const progressLabel = document.getElementById('reading-progress-label');
  const remainingLabel = document.getElementById('reading-remaining-label');

  async function renderMermaidBlocks() {
    if (!(articleContent instanceof HTMLElement)) return;

    const blocks = articleContent.querySelectorAll('pre > code.language-mermaid');
    blocks.forEach((code) => {
      const pre = code.parentElement;
      if (!(pre instanceof HTMLPreElement)) return;

      const diagram = document.createElement('div');
      diagram.className = 'mermaid';
      diagram.textContent = code.textContent || '';

      const frame = document.createElement('div');
      frame.className = 'mermaid-diagram';
      frame.appendChild(diagram);

      pre.replaceWith(frame);
    });

    if (blocks.length === 0) return;

    try {
      const { default: mermaid } = await import('mermaid');
      mermaid.initialize({
        startOnLoad: false,
        securityLevel: 'strict',
        theme: 'default',
      });
      await mermaid.run({ querySelector: '#article-content .mermaid' });
    } catch (err) {
      console.error('Mermaid render failed:', err);
    }
  }

  function getCodeLanguage(code) {
    if (!(code instanceof HTMLElement)) return 'Plain Text';

    const languageClass = Array.from(code.classList).find((className) => className.startsWith('language-'));
    const language = languageClass?.replace('language-', '').trim();

    if (!language || language === 'text' || language === 'txt' || language === 'plaintext') return 'Plain Text';
    return language;
  }

  function enhanceCodeBlocks() {
    if (!(articleContent instanceof HTMLElement)) return;

    const blocks = articleContent.querySelectorAll('pre');
    blocks.forEach((pre) => {
      if (!(pre instanceof HTMLPreElement)) return;
      if (pre.dataset.enhanced === 'true') return;

      const code = pre.querySelector(':scope > code');
      if (!(code instanceof HTMLElement)) return;

      const language = getCodeLanguage(code);
      const isPlainText = language === 'Plain Text';
      pre.dataset.enhanced = 'true';
      pre.dataset.language = language;
      if (isPlainText) pre.classList.add('is-plain-code');

      const toolbar = document.createElement('div');
      toolbar.className = 'code-block-toolbar';

      const label = document.createElement('span');
      label.className = 'code-block-language';
      label.textContent = language;

      const copyButton = document.createElement('button');
      copyButton.className = 'code-copy-button';
      copyButton.type = 'button';
      copyButton.setAttribute('aria-label', '复制代码');
      copyButton.innerHTML = `
        <svg viewBox="0 0 24 24" aria-hidden="true" class="code-copy-icon">
          <rect x="9" y="9" width="11" height="11" rx="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
        <span>复制</span>
      `;

      copyButton.addEventListener('click', async () => {
        const text = code.textContent || '';
        try {
          await navigator.clipboard.writeText(text);
          copyButton.classList.add('is-copied');
          copyButton.querySelector('span').textContent = '已复制';
          window.setTimeout(() => {
            copyButton.classList.remove('is-copied');
            copyButton.querySelector('span').textContent = '复制';
          }, 1600);
        } catch (err) {
          console.error('Copy code failed:', err);
          copyButton.querySelector('span').textContent = '复制失败';
          window.setTimeout(() => {
            copyButton.querySelector('span').textContent = '复制';
          }, 1600);
        }
      });

      toolbar.append(label, copyButton);
      pre.prepend(toolbar);
    });
  }

  function updateReadingProgress() {
    if (!(articleContent instanceof HTMLElement)) return;
    if (!(progressBar instanceof HTMLElement)) return;
    if (!(progressLabel instanceof HTMLElement)) return;
    if (!(remainingLabel instanceof HTMLElement)) return;

    const rect = articleContent.getBoundingClientRect();
    const viewportHeight = window.innerHeight;
    const totalScrollable = Math.max(articleContent.offsetHeight - viewportHeight * 0.35, 1);
    const progressed = Math.min(Math.max(viewportHeight * 0.65 - rect.top, 0), totalScrollable);
    const percent = Math.min(100, Math.max(0, Math.round((progressed / totalScrollable) * 100)));

    progressBar.style.width = `${percent}%`;
    progressLabel.textContent = `阅读进度 ${percent}%`;

    const remaining = Math.max(1, Math.ceil(((100 - percent) / 100) * 5));
    remainingLabel.textContent = percent >= 96 ? '即将读完' : `预计剩余约 ${remaining} 分钟`;
  }

  renderMermaidBlocks().then(enhanceCodeBlocks);
  updateReadingProgress();
  window.addEventListener('scroll', updateReadingProgress, { passive: true });
  window.addEventListener('resize', updateReadingProgress);
</script>

<style>
  .article-title-display {
    font-family: 'KaiTi', 'STKaiti', 'Noto Serif SC', 'Songti SC', serif;
    color: #4a332e;
    font-weight: 620;
    letter-spacing: 0;
  }

  .article-description {
    font-family: 'FangSong', 'STFangsong', 'Songti SC', 'Noto Serif SC', serif;
    color: #7e746d;
    font-weight: 520;
    line-height: 1.56;
    letter-spacing: 0;
  }

  .article-cover {
    height: min(42vw, 360px);
    min-height: 220px;
    border-bottom: 1px solid rgb(226 232 240);
    background: #f8fafc;
  }

  .article-word-total {
    font-family: 'KaiTi', 'STKaiti', 'Noto Serif SC', 'Songti SC', serif;
    color: #5f4a42;
    font-weight: 620;
    letter-spacing: 0;
  }

  .article-prose {
    font-family: 'Noto Serif SC', 'Songti SC', 'STSong', serif;
    font-size: 1.02rem;
    line-height: 1.62;
    letter-spacing: 0;
    color: #4f463f;
  }

  .article-prose :global(p) {
    margin-top: 0.82rem;
    margin-bottom: 0.82rem;
    line-height: 1.62;
  }

  .article-prose :global(li) {
    margin-top: 0.28rem;
    margin-bottom: 0.28rem;
    line-height: 1.58;
  }

  .article-prose :global(ul),
  .article-prose :global(ol) {
    margin-top: 0.82rem;
    margin-bottom: 0.82rem;
  }

  .article-prose :global(h2),
  .article-prose :global(h3),
  .article-prose :global(h4) {
    font-family: 'KaiTi', 'STKaiti', 'Noto Serif SC', 'Songti SC', serif;
    color: #4a332e;
    font-weight: 620;
    letter-spacing: 0;
    line-height: 1.22;
  }

  .article-prose :global(blockquote p) {
    font-family: 'FangSong', 'STFangsong', 'Songti SC', 'Noto Serif SC', serif;
    color: #7e746d;
    line-height: 1.56;
  }

  .article-prose :global(:not(pre) > code) {
    border: 1px solid rgba(251, 146, 60, 0.18);
    border-radius: 0.45rem;
    background: linear-gradient(180deg, rgba(255, 247, 237, 0.95), rgba(255, 237, 213, 0.72));
    padding: 0.12rem 0.38rem;
    color: #c2410c;
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.88em;
    font-weight: 600;
  }

  .article-prose :global(pre) {
    position: relative;
    margin: 1.8rem 0;
    overflow: hidden;
    border: 1px solid rgba(226, 223, 216, 0.95);
    border-radius: 0.9rem;
    background: #f7f6f3;
    box-shadow: 0 12px 30px rgba(15, 23, 42, 0.06);
  }

  .article-prose :global(.code-block-toolbar) {
    position: sticky;
    top: 0;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.45rem;
    min-height: 2.55rem;
    border-bottom: 1px solid rgba(226, 223, 216, 0.75);
    background: rgba(250, 250, 249, 0.92);
    padding: 0.35rem 0.55rem 0.35rem 0.85rem;
    backdrop-filter: blur(10px);
  }

  .article-prose :global(.code-block-language) {
    border-radius: 0.55rem;
    background: rgba(255, 255, 255, 0.86);
    color: #78716c;
    padding: 0.3rem 0.55rem;
    font-family: 'Inter', 'Noto Sans SC', system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1;
  }

  .article-prose :global(.code-copy-button) {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid rgba(214, 211, 205, 0.95);
    border-radius: 0.55rem;
    background: #ffffff;
    color: #6b7280;
    padding: 0.32rem 0.52rem;
    font-family: 'Inter', 'Noto Sans SC', system-ui, sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    line-height: 1;
    box-shadow: 0 6px 14px rgba(15, 23, 42, 0.06);
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background 180ms ease;
  }

  .article-prose :global(.code-copy-button:hover) {
    border-color: rgba(168, 162, 158, 0.95);
    background: #fafaf9;
    color: #1f2937;
  }

  .article-prose :global(.code-copy-button.is-copied) {
    border-color: rgba(16, 185, 129, 0.35);
    background: #ecfdf5;
    color: #047857;
  }

  .article-prose :global(.code-copy-icon) {
    width: 0.95rem;
    height: 0.95rem;
    fill: none;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .article-prose :global(pre code) {
    display: block;
    overflow-x: auto;
    padding: 1.05rem 1.25rem 1.2rem;
    background: transparent;
    color: #24292f;
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.92rem;
    line-height: 1.75;
    tab-size: 2;
  }

  .article-prose :global(pre.is-plain-code code),
  .article-prose :global(pre.is-plain-code code *) {
    color: #242424 !important;
  }

  .article-prose :global(pre code .line) {
    min-height: 1.75em;
  }

  .article-prose :global(pre code::-webkit-scrollbar) {
    height: 0.55rem;
  }

  .article-prose :global(pre code::-webkit-scrollbar-thumb) {
    border-radius: 999px;
    background: rgba(168, 162, 158, 0.42);
  }

  .article-prose :global(.mermaid-diagram) {
    margin: 1.8rem 0;
    overflow-x: auto;
    border: 1px solid rgba(226, 232, 240, 0.95);
    border-radius: 1rem;
    background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
    padding: 1.25rem;
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.08);
  }

  .article-prose :global(.mermaid) {
    display: flex;
    min-width: max-content;
    justify-content: center;
  }

  .article-prose :global(.mermaid svg) {
    height: auto;
    max-width: 100%;
  }
</style>
