---
import { Icon } from 'astro-icon/components';
const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-stone-200/80 backdrop-blur-xl bg-white/82 shadow-[0_14px_40px_rgba(148,163,184,0.10)]">
  <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <Icon name="lucide:flame" class="w-5 h-5 text-amber-500 group-hover:text-amber-400 transition-all duration-300 group-hover:scale-110 group-hover:drop-shadow-[0_0_8px_rgba(245,158,11,0.35)]" />
      <span class="text-lg font-semibold text-slate-800 group-hover:text-amber-500 transition-colors duration-200">
        晨熠
      </span>
    </a>
    <div class="flex items-center gap-6 text-sm">
      <a
        href="/"
        class:list={[
          'flex items-center gap-1.5 transition-colors duration-200',
          currentPath === '/' ? 'text-amber-600' : 'text-stone-500 hover:text-amber-500',
        ]}
      >
        <Icon name="lucide:home" class="w-4 h-4" />
        首页
      </a>
      <a
        href="/blog"
        class:list={[
          'flex items-center gap-1.5 transition-colors duration-200',
          currentPath.startsWith('/blog') ? 'text-sky-600' : 'text-stone-500 hover:text-sky-600',
        ]}
      >
        <Icon name="lucide:book-open" class="w-4 h-4" />
        文章
      </a>
      <a
        href="https://github.com/rain1andsnow2a"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-1.5 text-stone-500 hover:text-slate-700 transition-colors duration-200"
      >
        <Icon name="lucide:github" class="w-4 h-4" />
        GitHub
      </a>
    </div>
  </nav>
</header>
