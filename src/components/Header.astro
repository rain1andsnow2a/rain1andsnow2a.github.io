---
const currentPath = Astro.url.pathname;
---

<header class="border-b border-slate-800">
  <nav class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 group">
      <span class="text-amber-400 text-xl">✦</span>
      <span class="text-lg font-semibold text-slate-100 group-hover:text-amber-400 transition-colors duration-200">
        晨熠
      </span>
    </a>
    <div class="flex items-center gap-6 text-sm">
      <a
        href="/"
        class:list={[
          'transition-colors duration-200',
          currentPath === '/' ? 'text-amber-400' : 'text-slate-400 hover:text-amber-400',
        ]}
      >
        首页
      </a>
      <a
        href="/blog"
        class:list={[
          'transition-colors duration-200',
          currentPath.startsWith('/blog') ? 'text-amber-400' : 'text-slate-400 hover:text-amber-400',
        ]}
      >
        文章
      </a>
      <a
        href="https://github.com/rain1andsnow2"
        target="_blank"
        rel="noopener noreferrer"
        class="text-slate-400 hover:text-amber-400 transition-colors duration-200"
      >
        GitHub
      </a>
    </div>
  </nav>
</header>
