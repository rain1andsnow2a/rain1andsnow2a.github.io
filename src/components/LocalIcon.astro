---
import lucideIcons from '@iconify-json/lucide/icons.json';

export interface Props {
  name: string;
  class?: string;
  label?: string;
}

const { name, class: className = 'h-4 w-4', label } = Astro.props;
const icon = lucideIcons.icons[name];

if (!icon) {
  throw new Error(`Missing local Lucide icon: ${name}`);
}

const width = icon.width ?? lucideIcons.width ?? 24;
const height = icon.height ?? lucideIcons.height ?? 24;
---

<svg
  class={className}
  viewBox={`0 0 ${width} ${height}`}
  role={label ? 'img' : undefined}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  set:html={icon.body}
></svg>
